---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType,
  canonicalUrl,
  noindex = false,
} = Astro.props;

const phone = '055-432-9232';
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-dark antialiased font-sans">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Cookie Consent Banner -->
    <div id="cookie-consent" class="fixed bottom-0 inset-x-0 z-[100] bg-dark text-white p-4 shadow-lg transform translate-y-full transition-transform duration-300">
      <div class="container mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-center md:text-start">
          אתר זה משתמש בעוגיות (cookies) לשיפור חוויית הגלישה וניתוח תנועה.
          <a href="/privacy/" class="underline hover:text-brand-300">מדיניות פרטיות</a>
        </p>
        <div class="flex gap-3">
          <button id="cookie-reject" class="px-4 py-2 text-sm border border-white/30 rounded hover:bg-white/10 transition">
            דחייה
          </button>
          <button id="cookie-accept" class="px-4 py-2 text-sm bg-accent hover:bg-accent-dark rounded transition">
            אישור
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Floating Phone Button -->
    <a
      href={`tel:${phone}`}
      class="fixed bottom-4 start-4 z-50 md:hidden w-14 h-14 bg-accent hover:bg-accent-dark text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
      aria-label="התקשרו אלינו"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
    </a>

    <!-- Accessibility Widget -->
    <div id="accessibility-widget" class="fixed bottom-4 end-4 z-50">
      <button
        id="accessibility-toggle"
        class="w-12 h-12 bg-brand-700 hover:bg-brand-800 text-white rounded-full shadow-lg flex items-center justify-center transition-all duration-300"
        aria-label="הגדרות נגישות"
      >
        <!-- Standard accessibility icon (person with arms out) -->
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="4" r="2"/>
          <path d="M19 13v-2c-1.54.02-3.09-.75-4.07-1.83l-1.29-1.43c-.17-.19-.38-.34-.61-.45-.01 0-.01-.01-.02-.01H13c-.35-.2-.75-.3-1.19-.26C10.76 7.11 10 8.04 10 9.09V15c0 1.1.9 2 2 2h5v5h2v-5.5c0-1.1-.9-2-2-2h-3v-3.45c1.29 1.07 3.25 1.94 5 1.95zm-6.17 5c-.41 1.16-1.52 2-2.83 2-1.66 0-3-1.34-3-3 0-1.31.84-2.41 2-2.83V12.1c-2.28.46-4 2.48-4 4.9 0 2.76 2.24 5 5 5 2.42 0 4.44-1.72 4.9-4h-2.07z"/>
        </svg>
      </button>
      <div id="accessibility-panel" class="hidden absolute bottom-14 end-0 bg-white rounded-lg shadow-xl border border-border p-4 w-64">
        <h3 class="font-bold text-dark mb-3">הגדרות נגישות</h3>
        <div class="space-y-2">
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition" data-action="increase-font">
            הגדלת גופן
          </button>
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition" data-action="decrease-font">
            הקטנת גופן
          </button>
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition" data-action="grayscale">
            מצב גווני אפור
          </button>
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition" data-action="high-contrast">
            ניגודיות גבוהה
          </button>
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition" data-action="highlight-links">
            הדגשת קישורים
          </button>
          <button class="accessibility-btn w-full text-start px-3 py-2 rounded hover:bg-surface transition text-red-600" data-action="reset">
            איפוס הגדרות
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      // Accessibility Widget
      const toggle = document.getElementById('accessibility-toggle');
      const panel = document.getElementById('accessibility-panel');

      toggle?.addEventListener('click', () => {
        panel?.classList.toggle('hidden');
      });

      document.querySelectorAll('.accessibility-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const action = e.target.dataset.action;
          const html = document.documentElement;

          switch(action) {
            case 'increase-font':
              const currentSize = parseFloat(getComputedStyle(html).fontSize);
              html.style.fontSize = (currentSize + 2) + 'px';
              break;
            case 'decrease-font':
              const currSize = parseFloat(getComputedStyle(html).fontSize);
              html.style.fontSize = Math.max(12, currSize - 2) + 'px';
              break;
            case 'grayscale':
              html.classList.toggle('grayscale');
              break;
            case 'high-contrast':
              html.classList.toggle('contrast-more');
              break;
            case 'highlight-links':
              html.classList.toggle('highlight-links');
              break;
            case 'reset':
              html.style.fontSize = '';
              html.classList.remove('grayscale', 'contrast-more', 'highlight-links');
              break;
          }
        });
      });

      // Close panel when clicking outside
      document.addEventListener('click', (e) => {
        if (!document.getElementById('accessibility-widget')?.contains(e.target)) {
          panel?.classList.add('hidden');
        }
      });
    </script>

    <style is:global>
      .grayscale { filter: grayscale(100%); }
      .contrast-more { filter: contrast(1.4); }
      .highlight-links a { background-color: yellow !important; color: black !important; }
    </style>

    <script is:inline>
      // Cookie Consent
      (function() {
        const consent = localStorage.getItem('cookie-consent');
        const banner = document.getElementById('cookie-consent');

        if (!consent && banner) {
          // Show banner after a short delay
          setTimeout(() => {
            banner.classList.remove('translate-y-full');
          }, 1000);
        }

        document.getElementById('cookie-accept')?.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'accepted');
          banner?.classList.add('translate-y-full');
        });

        document.getElementById('cookie-reject')?.addEventListener('click', () => {
          localStorage.setItem('cookie-consent', 'rejected');
          banner?.classList.add('translate-y-full');
        });
      })();
    </script>
  </body>
</html>
