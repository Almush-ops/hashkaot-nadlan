---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import CTASection from '../components/CTASection.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

// Person schemas for EEAT
const maayanSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'מעין ליבנה',
  jobTitle: 'שמאית מקרקעין',
  description: 'שמאית מקרקעין מוסמכת עם 15 שנות ניסיון. התמחות בבדיקות השקעות ונכסים.',
  knowsAbout: ['שמאות מקרקעין', 'בדיקת נכסים', 'הערכת שווי', 'השקעות נדל״ן'],
  worksFor: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
};

const orSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'אור ליבנה',
  jobTitle: 'מלווה משקיעים',
  description: 'מלווה משקיעים עם רקע הייטק (גרניולט → אינטל). יועץ משכנתאות ובעל רישיון תיווך.',
  knowsAbout: ['ליווי משקיעים', 'יעוץ משכנתאות', 'ניהול משא ומתן', 'ניתוח השקעות'],
  worksFor: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
};

// Organization schema
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'השקעות נדל״ן - מעין ואור ליבנה',
  url: 'https://hashkaot-nadlan.co.il',
  description: 'ליווי משקיעי נדל״ן ובדיקות קרקע על ידי שמאית מקרקעין מוסמכת.',
  areaServed: ['חיפה', 'קריות', 'נתניה', 'ראשון לציון', 'גבעת שמואל'],
  priceRange: '₪₪',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '41',
  },
};
---

<BaseLayout
  title="אודות מעין ואור ליבנה | שמאית מקרקעין + מלווה משקיעים"
  description="הכירו את מעין ואור ליבנה - שמאית מקרקעין מוסמכת עם 15 שנות ניסיון ומלווה משקיעים עם רקע הייטק. 617+ בדיקות, 98+ משקיעים מרוצים, 5.0 ב-41 ביקורות."
>
  <SchemaOrg schema={maayanSchema} />
  <SchemaOrg schema={orSchema} />
  <SchemaOrg schema={orgSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark leading-tight mb-6">
          הכירו את מעין ואור ליבנה
        </h1>
        <p class="text-lg md:text-xl text-muted mb-8">
          שילוב ייחודי של <strong>שמאית מקרקעין מוסמכת</strong> עם 15 שנות ניסיון
          ו<strong>מלווה משקיעים</strong> עם רקע הייטק ואקזיט.
          המומחיות שאתם צריכים להשקעה חכמה בנדל״ן.
        </p>

        <!-- Stats Row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto">
          <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
            <div class="text-2xl font-bold text-brand-600">617+</div>
            <div class="text-sm text-muted">בדיקות וייעוצים</div>
          </div>
          <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
            <div class="text-2xl font-bold text-brand-600">98+</div>
            <div class="text-sm text-muted">משקיעים מרוצים</div>
          </div>
          <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
            <div class="text-2xl font-bold text-brand-600">15</div>
            <div class="text-sm text-muted">שנות ניסיון</div>
          </div>
          <div class="bg-white rounded-xl p-4 shadow-sm border border-border">
            <div class="text-2xl font-bold text-accent">5.0</div>
            <div class="text-sm text-muted">ב-41 ביקורות</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- Maayan Profile -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
          <!-- Photo -->
          <div class="flex-shrink-0 w-full md:w-72">
            <!-- TODO: להחליף לתמונה אמיתית של מעין -->
            <div class="aspect-[3/4] bg-brand-100 rounded-2xl flex items-center justify-center relative overflow-hidden">
              <span class="text-6xl font-bold text-brand-600">מ</span>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-brand-900/80 to-transparent p-4">
                <div class="text-white text-sm font-medium">שמאית מקרקעין מוסמכת</div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="flex-1">
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-2">
              מעין ליבנה
            </h2>
            <p class="text-brand-600 font-semibold text-lg mb-4">
              שמאית מקרקעין מוסמכת | 15 שנות ניסיון
            </p>

            <div class="prose prose-lg max-w-none mb-6">
              <p class="text-muted">
                מעין היא שמאית מקרקעין מוסמכת מטעם משרד המשפטים עם 15 שנות ניסיון בשוק הישראלי.
                התמחותה העיקרית היא בבדיקות נכסים להשקעה ובדיקות קרקע - לזהות את מה שהמוכרים
                לא רוצים שתראו.
              </p>
              <p class="text-muted">
                במהלך הקריירה שלה ביצעה מעין אלפי בדיקות נכסים וקרקעות, וחסכה ללקוחותיה
                מיליוני שקלים בעסקאות שלא היו שוות את המחיר או שכללו בעיות נסתרות.
              </p>
            </div>

            <!-- Credentials -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
              <div class="flex items-center gap-3 p-3 bg-brand-50 rounded-lg">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-sm text-dark">רישיון שמאות מקרקעין - משרד המשפטים</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-brand-50 rounded-lg">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <span class="text-sm text-dark">התמחות בנכסי השקעה וקרקעות</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-brand-50 rounded-lg">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                </svg>
                <span class="text-sm text-dark">340+ בדיקות קרקע</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-brand-50 rounded-lg">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span class="text-sm text-dark">480+ בדיקות דירות</span>
              </div>
            </div>

            <!-- Quote -->
            <blockquote class="border-r-4 border-accent pr-4 text-muted italic">
              "כשמאית, היתרון שלי הוא שאני רואה את התמונה המלאה - לא רק את מה שהמוכר רוצה להראות.
              אני יודעת לזהות בעיות לפני שהן הופכות לבעיות שלכם."
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Or Profile -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row-reverse gap-8 md:gap-12 items-start">
          <!-- Photo -->
          <div class="flex-shrink-0 w-full md:w-72">
            <!-- TODO: להחליף לתמונה אמיתית של אור -->
            <div class="aspect-[3/4] bg-brand-100 rounded-2xl flex items-center justify-center relative overflow-hidden">
              <span class="text-6xl font-bold text-brand-600">א</span>
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-brand-900/80 to-transparent p-4">
                <div class="text-white text-sm font-medium">מלווה משקיעים</div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="flex-1">
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-2">
              אור ליבנה
            </h2>
            <p class="text-brand-600 font-semibold text-lg mb-4">
              מלווה משקיעים | רקע הייטק + אקזיט
            </p>

            <div class="prose prose-lg max-w-none mb-6">
              <p class="text-muted">
                אור הגיע לעולם הנדל״ן מרקע הייטקי - כחלק מצוות ההנדסה בגרניולט, שנמכרה לאינטל.
                הרקע הטכנולוגי מתבטא בגישה מבוססת נתונים להשקעות - כל החלטה נתמכת בניתוח מעמיק,
                לא באינטואיציה או לחץ מכירתי.
              </p>
              <p class="text-muted">
                מעבר לליווי משקיעים, אור הוא יועץ משכנתאות מוסמך עם קשרים בכל הבנקים,
                ובעל רישיון תיווך מטעם משרד המשפטים. השילוב הזה מאפשר ליווי מקיף מהרגע הראשון
                ועד לקבלת המפתח.
              </p>
            </div>

            <!-- Credentials -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg border border-border">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-sm text-dark">8 שנים הייטק (גרניולט → אינטל)</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg border border-border">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-sm text-dark">יועץ משכנתאות מוסמך</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg border border-border">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-sm text-dark">רישיון תיווך - משרד המשפטים</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-white rounded-lg border border-border">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <span class="text-sm text-dark">98+ משקיעים ליווינו</span>
              </div>
            </div>

            <!-- Quote -->
            <blockquote class="border-r-4 border-accent pr-4 text-muted italic">
              "בשנים האחרונות זכינו ללוות משקיעים בקבלת החלטות בעסקאות נדל״ן. מי שלא הגיע מהתחום
              והצליח לקבל החלטה נכונה וכלכלית - ריגש אותנו. בזכותם הבנו את ערך הליווי."
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us - The Combination -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
            למה דווקא אנחנו?
          </h2>
          <p class="text-muted text-lg">
            השילוב של שמאית מקרקעין ומלווה משקיעים נדיר בשוק - ומאפשר ליווי ברמה אחרת
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">בדיקות על ידי שמאית אמיתית</h3>
            <p class="text-muted">
              לא "בודק נכסים" או "יועץ". שמאית מקרקעין מוסמכת עם רישיון רשמי ו-15 שנות ניסיון.
              החתימה שלה עומדת מאחורי כל בדיקה.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">מחיר קבוע = אפס ניגוד אינטרסים</h3>
            <p class="text-muted">
              מתווך מרוויח אחוזים - יש לו אינטרס שתסגרו מהר ויקר. אנחנו גובים מחיר קבוע,
              האינטרס שלנו הוא שתעשו עסקה טובה - גם אם לוקח זמן.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">אנחנו בעצמנו - לא שליחים</h3>
            <p class="text-muted">
              מעין ואור עובדים איתכם ישירות. אין מתמחים, אין נציגים, אין "צוות".
              אתם מדברים עם מי שאחראי - תמיד.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">גישה מבוססת נתונים</h3>
            <p class="text-muted">
              הרקע ההייטקי של אור + הניסיון של מעין = החלטות מבוססות על עובדות ומספרים.
              לא "הרגשות בטן" או "שמעתי ש...".
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8">
          הגישה שלנו
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="w-14 h-14 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mx-auto mb-4">
