---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'בדיקת כדאיות דירה' },
];

const faqItems = [
  {
    question: 'מה כולל שירות בדיקת כדאיות דירה?',
    answer: 'השירות כולל: ניתוח פיננסי מקיף (תשואה צפויה, עלויות נלוות, תזרים מזומנים), בדיקת מצב הנכס, השוואה לנכסים דומים באזור, והמלצה מנומקת.',
  },
  {
    question: 'כמה עולה בדיקת כדאיות דירה?',
    answer: 'עלות הבדיקה היא 1,800 ש״ח + מע״מ. זהו מחיר קבוע שכולל את כל הבדיקות והניתוחים.',
  },
  {
    question: 'כמה זמן לוקחת הבדיקה?',
    answer: 'הבדיקה לוקחת 2-3 ימי עבודה. בסיום תקבלו דוח מפורט עם כל הממצאים וההמלצות.',
  },
  {
    question: 'האם הבדיקה כוללת ביקור בנכס?',
    answer: 'כן, הבדיקה כוללת ביקור בנכס להערכת מצבו הפיזי, הבניין והסביבה. זה חלק חשוב מההערכה הכוללת.',
  },
  {
    question: 'מה ההבדל בינכם לשמאי רגיל?',
    answer: 'שמאי רגיל נותן הערכת שווי. אנחנו נותנים ניתוח כדאיות כמשקיעים - האם כדאי לקנות את הנכס הזה, מה התשואה הצפויה, מה הסיכונים ומה הפוטנציאל. מעוניינים בליווי מלא? <a href="/investor-consulting/" class="text-brand-600 hover:underline">ראו את שירות ליווי משקיעים לרכישת דירה ←</a>',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'בדיקת כדאיות דירה',
  description: 'ניתוח פיננסי מקיף לדירה להשקעה - תשואה, עלויות, סיכונים והמלצה',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
  areaServed: 'ישראל',
  serviceType: 'ייעוץ השקעות נדל״ן',
  offers: {
    '@type': 'Offer',
    price: '1800',
    priceCurrency: 'ILS',
  },
};
---

<BaseLayout
  title="בדיקת כדאיות דירה להשקעה"
  description="בדיקת כדאיות מקיפה לדירה להשקעה - ניתוח תשואה, עלויות נלוות, סיכונים והמלצה. על ידי שמאית מקרקעין. 1,800 ש״ח + מע״מ."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="בדיקת כדאיות דירה להשקעה"
    subtitle="לפני שקונים דירה להשקעה - חשוב לדעת אם זו באמת עסקה טובה. ניתוח פיננסי מקיף שיעזור לכם לקבל החלטה מושכלת."
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="הזמינו בדיקת כדאיות"
  />

  <TrustBar variant="light" />

  <!-- What We Check -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-12 text-center">
          מה אנחנו בודקים?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              title: 'ניתוח פיננסי',
              items: ['תשואה שנתית צפויה', 'עלויות רכישה ונלוות', 'תזרים מזומנים חודשי', 'נקודת איזון', 'השוואה להשקעות חלופיות'],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
            },
            {
              title: 'בדיקת הנכס',
              items: ['מצב פיזי ותחזוקה', 'שיפוצים נדרשים', 'מצב הבניין והוועד', 'פוטנציאל השבחה', 'בעיות נסתרות'],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
            },
            {
              title: 'ניתוח שוק',
              items: ['שכירות ממוצעת באזור', 'ביקוש לדירות דומות', 'מגמות מחירים', 'תחרות בשוק', 'פוטנציאל עליית ערך'],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
            },
          ].map((category) => (
            <div class="bg-surface rounded-xl p-6 border border-border">
              <div class="w-14 h-14 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4" set:html={category.icon} />
              <h3 class="font-heading font-bold text-dark text-lg mb-4">{category.title}</h3>
              <ul class="space-y-2">
                {category.items.map((item) => (
                  <li class="flex items-center gap-2 text-muted text-sm">
                    <svg class="w-4 h-4 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- The Report -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה תקבלו בסוף הבדיקה?
        </h2>

        <div class="bg-white rounded-2xl p-8 border border-border">
          <div class="space-y-6">
            {[
              {
                title: 'דוח מפורט בכתב',
                desc: 'דוח מקיף עם כל הממצאים, הנתונים והחישובים - שתוכלו לחזור אליו גם בעתיד.',
              },
              {
                title: 'טבלת תשואה',
                desc: 'חישוב מפורט של התשואה הצפויה, כולל כל העלויות הנלוות וההכנסות.',
              },
              {
                title: 'השוואה לחלופות',
                desc: 'השוואה לנכסים דומים באזור ולהשקעות אלטרנטיביות.',
              },
              {
                title: 'המלצה מנומקת',
                desc: 'האם לקנות, לוותר, או לנסות להוריד מחיר - עם הסבר מפורט.',
              },
              {
                title: 'שיחת סיכום',
                desc: 'שיחה אישית לעבור על הממצאים ולענות על כל השאלות שלכם.',
              },
            ].map((item, index) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-8 h-8 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
                  {index + 1}
                </div>
                <div>
                  <h3 class="font-semibold text-dark mb-1">{item.title}</h3>
                  <p class="text-muted text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
          מחיר השירות
        </h2>
        <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
          <div class="text-5xl font-bold text-brand-600 mb-2">₪1,800</div>
          <div class="text-muted mb-6">+ מע״מ | כולל את כל הבדיקות</div>
          <ul class="text-start space-y-3 mb-8">
            {['ניתוח פיננסי מקיף', 'ביקור בנכס', 'בדיקת שוק', 'דוח מפורט בכתב', 'שיחת סיכום'].map((item) => (
              <li class="flex items-center gap-2 text-dark">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="#contact"
            class="block w-full py-4 bg-accent hover:bg-accent-dark text-white rounded-md font-semibold transition-all duration-300"
          >
            הזמינו בדיקה עכשיו
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="מצאתם דירה להשקעה?"
    subtitle="לפני שחותמים - בואו נבדוק אם זו באמת עסקה טובה"
    ctaText="הזמינו בדיקה"
  />

  <FAQ
    title="שאלות נפוצות על בדיקת כדאיות"
    items={faqItems}
  />

  <ContactForm
    title="הזמינו בדיקת כדאיות"
    subtitle="מלאו את הפרטים ונחזור אליכם בהקדם"
  />
</BaseLayout>
