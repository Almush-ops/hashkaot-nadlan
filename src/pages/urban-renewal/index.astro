---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';


const faqItems = [
  {
    question: 'מה ההבדל בין תמ״א 38 לפינוי בינוי?',
    answer: 'תמ״א 38 מתייחסת לחיזוק/הריסה של בניינים בודדים. פינוי בינוי הוא פרויקט גדול יותר שכולל מתחמים שלמים (לפחות 24 דירות בד״כ), עם תכנון מחודש של כל האזור. בפינוי בינוי התמורות לדיירים בדרך כלל גדולות יותר, אבל התהליך ארוך יותר.',
  },
  {
    question: 'כמה עולה ייעוץ בהתחדשות עירונית?',
    answer: 'פגישת ייעוץ ראשונית היא ללא עלות. בדיקת הצעת יזם ספציפית עולה 2,000-3,500 ש״ח. ליווי מקיף של כל התהליך (כולל משא ומתן והשוואת הצעות) - צרו קשר להצעה מותאמת.',
  },
  {
    question: 'כמה זמן לוקח פרויקט התחדשות עירונית?',
    answer: 'תמ״א 38/1 (חיזוק): 2-3 שנים. תמ״א 38/2 (הריסה ובנייה): 4-6 שנים. פינוי בינוי: 7-12 שנים. שימו לב - אלה הזמנים מרגע התחלת הבנייה. התהליך עד לשם יכול לקחת עוד 3-5 שנים.',
  },
  {
    question: 'האם כדאי לקנות דירה בבניין שעובר התחדשות?',
    answer: 'זה תלוי בשלב הפרויקט, בתמורות המוצעות, ובמחיר הדירה הנוכחי. לפעמים זו הזדמנות מצוינת, לפעמים זה מלכוד. אנחנו יכולים לבדוק את הכדאיות של עסקה כזו עבורכם. ראו גם <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות דירה להשקעה</a>.',
  },
  {
    question: 'מה תפקידכם בתהליך?',
    answer: 'אנחנו מייעצים לבעלי דירות או למשקיעים: הערכת שווי הזכויות שלכם, בדיקת הצעות מיזמים, השוואה בין יזמים שונים, ייעוץ במשא ומתן, ובדיקת חוזים לפני חתימה. אנחנו עובדים עבורכם - לא עבור היזם.',
  },
  {
    question: 'מה התמורות הסטנדרטיות בפרויקט התחדשות?',
    answer: 'בתמ״א 38/2 ופינוי-בינוי: דירה חדשה גדולה יותר (תוספת של 12-25 מ״ר), מרפסת שמש, ממ״ד, חניה ומחסן. בתמ״א 38/1: שיפוץ הדירה, מעלית, חניה, וממ״ד. התמורות המדויקות תלויות בפרויקט ובמיקום.',
  },
  {
    question: 'איך בוחרים יזם להתחדשות עירונית?',
    answer: 'צריך לבדוק: ניסיון קודם (פרויקטים שהושלמו), יציבות פיננסית, ערבויות שהוא נותן, התמורות המוצעות, ותנאי החוזה. אנחנו עוזרים להשוות בין יזמים ולזהות את ההצעה הטובה ביותר.',
  },
  {
    question: 'מה הסיכונים בהתחדשות עירונית?',
    answer: 'הסיכונים העיקריים: עיכובים משמעותיים (שנים), יזם שנקלע לקשיים, ירידת ערך הדירה הישנה בזמן ההמתנה, ומחלוקות בין דיירים. ייעוץ מקצועי עוזר לזהות סימני אזהרה מראש.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ייעוץ התחדשות עירונית',
  description: 'ייעוץ מקצועי בפרויקטי התחדשות עירונית - תמ״א 38, פינוי בינוי והריסה ובנייה',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
  areaServed: 'ישראל',
  serviceType: 'ייעוץ נדל״ן',
};
---

<BaseLayout
  title="ייעוץ התחדשות עירונית"
  description="ייעוץ מקצועי בפרויקטי התחדשות עירונית - תמ״א 38, פינוי בינוי והריסה ובנייה. ליווי בעלי דירות ומשקיעים. פגישת ייעוץ ראשונית חינם."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="ייעוץ התחדשות עירונית"
    subtitle="תמ״א 38, פינוי בינוי, הריסה ובנייה - אנחנו מלווים בעלי דירות ומשקיעים בכל שלבי התהליך. כדי שתדעו מה מגיע לכם ולא תוותרו על זכויות."
    
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="פגישת ייעוץ חינם"
  />

  <TrustBar variant="light" />

  <!-- Types of Projects -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-12 text-center">
          סוגי פרויקטי התחדשות עירונית
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              title: 'תמ״א 38/1',
              subtitle: 'חיזוק ותוספת',
              items: ['חיזוק מבנה קיים', 'תוספת קומות', 'מעלית וחניה', 'שדרוג הדירות', '2-3 שנים'],
              color: 'brand',
            },
            {
              title: 'תמ״א 38/2',
              subtitle: 'הריסה ובנייה',
              items: ['הריסת הבניין', 'בנייה חדשה מאפס', 'דירה חדשה וגדולה יותר', 'דיור חלופי בזמן הבנייה', '4-6 שנים'],
              color: 'accent',
            },
            {
              title: 'פינוי בינוי',
              subtitle: 'מתחם שלם',
              items: ['מתחם של מספר בניינים', 'תכנון מחודש של האזור', 'שטחים ציבוריים חדשים', 'דירה חדשה משודרגת', '7-10 שנים'],
              color: 'brand',
            },
          ].map((project) => (
            <div class={`bg-surface rounded-xl p-6 border-2 ${project.color === 'accent' ? 'border-accent' : 'border-brand-100'}`}>
              <div class="mb-4">
                <h3 class="font-heading font-bold text-dark text-xl">{project.title}</h3>
                <p class={`text-sm ${project.color === 'accent' ? 'text-accent' : 'text-brand-600'}`}>{project.subtitle}</p>
              </div>
              <ul class="space-y-2">
                {project.items.map((item) => (
                  <li class="flex items-center gap-2 text-muted text-sm">
                    <svg class={`w-4 h-4 flex-shrink-0 ${project.color === 'accent' ? 'text-accent' : 'text-brand-600'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How We Help -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          איך אנחנו עוזרים?
        </h2>

        <div class="space-y-6">
          {[
            {
              title: 'לבעלי דירות',
              items: [
                'הערכת שווי הזכויות שלכם',
                'ייעוץ בבחירת יזם',
                'בדיקת הצעות מיזמים',
                'ליווי במשא ומתן',
                'בדיקת חוזים לפני חתימה',
              ],
              icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
            },
            {
              title: 'למשקיעים',
              items: [
                'בדיקת כדאיות רכישת דירה בבניין להתחדשות',
                'הערכת שווי עתידי',
                'זיהוי הזדמנויות בשוק',
                'ניתוח סיכונים ותשואה צפויה',
                'ליווי עד לסגירת העסקה',
              ],
              icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
            },
          ].map((audience) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600" set:html={audience.icon} />
                <h3 class="font-heading font-bold text-dark text-lg">{audience.title}</h3>
              </div>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
                {audience.items.map((item) => (
                  <li class="flex items-center gap-2 text-muted text-sm">
                    <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Important -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          למה חשוב להתייעץ?
        </h2>

        <div class="space-y-6">
          {[
            {
              title: 'הבנת הזכויות שלכם',
              desc: 'רבים לא יודעים מה באמת מגיע להם. אנחנו נעזור לכם להבין את מלוא הזכויות שלכם בפרויקט.',
            },
            {
              title: 'משא ומתן חכם',
              desc: 'יזמים מציעים הצעות שונות. איך יודעים מה טוב ומה פחות? אנחנו נעזור לכם להשוות ולנהל משא ומתן.',
            },
            {
              title: 'הימנעות מטעויות',
              desc: 'חתימה על חוזה גרוע יכולה לעלות מאות אלפי שקלים. בדיקה מקצועית מראש חוסכת בעיות.',
            },
            {
              title: 'שקט נפשי',
              desc: 'פרויקט התחדשות לוקח שנים. חשוב להתחיל עם בסיס טוב ולדעת שעשיתם את הבחירה הנכונה.',
            },
          ].map((item) => (
            <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
              <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-1">{item.title}</h3>
                <p class="text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / Case Study -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          התמורות שהשגנו ללקוחות
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-white rounded-xl p-6 text-center border border-border">
            <div class="text-3xl font-bold text-brand-600 mb-2">+18 מ״ר</div>
            <div class="text-muted text-sm">תוספת ממוצעת לדירה בפרויקטים שליווינו</div>
          </div>
          <div class="bg-white rounded-xl p-6 text-center border border-border">
            <div class="text-3xl font-bold text-success-600 mb-2">320K ש״ח</div>
            <div class="text-muted text-sm">שווי ממוצע של שיפור בתמורות לאחר משא ומתן</div>
          </div>
          <div class="bg-white rounded-xl p-6 text-center border border-border">
            <div class="text-3xl font-bold text-brand-600 mb-2">23</div>
            <div class="text-muted text-sm">פרויקטי התחדשות שליווינו בחיפה והקריות</div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-6 border border-border">
          <h3 class="font-semibold text-dark text-lg mb-4">דוגמה: פינוי-בינוי בקריית שפרינצק, חיפה</h3>
          <p class="text-muted mb-4">
            ליווינו 4 בעלי דירות בבניין שקיבל הצעה מיזם. ההצעה הראשונית: דירת 4 חדרים (85 מ״ר) + חניה.
            לאחר בדיקה מעמיקה והשוואה ליזמים אחרים באזור, ניהלנו משא ומתן ושיפרנו את התמורות.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-surface rounded-lg p-4">
              <div class="text-sm text-muted mb-1">הצעה ראשונית:</div>
              <div class="font-semibold text-dark">85 מ״ר + חניה</div>
            </div>
            <div class="bg-success-50 rounded-lg p-4">
              <div class="text-sm text-muted mb-1">אחרי משא ומתן:</div>
              <div class="font-semibold text-success-700">97 מ״ר + חניה + מחסן + מרפסת 14 מ״ר</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- E-E-A-T Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div class="lg:col-span-1 flex justify-center">
            <img
              src="/images/team/maayan-portrait.webp"
              alt="מעיין ליבנה - שמאית מקרקעין מוסמכת"
              class="w-48 h-auto rounded-2xl shadow-lg"
              loading="lazy"
            />
          </div>

          <div class="lg:col-span-2">
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
              למה אנחנו יודעים לעזור בהתחדשות עירונית?
            </h2>
            <p class="text-muted mb-4">
              מעיין ליבנה, שמאית מקרקעין מוסמכת, ביצעה עשרות שומות לפרויקטי התחדשות עירונית - גם עבור יזמים וגם עבור דיירים. היא מכירה את המשחק משני הצדדים.
            </p>

            <ul class="space-y-3 mb-6">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">15 שנות ניסיון בשמאות מקרקעין</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">התמחות בפרויקטי תמ״א 38 ופינוי-בינוי</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">ניסיון בבדיקת הצעות יזמים והשוואה ביניהן</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">עובדת עבור הדיירים, לא עבור היזמים</span>
              </li>
            </ul>

            <p class="text-muted italic border-r-4 border-brand-200 pr-4">
              "יזמים מציעים מה שחושבים שתקבלו. בלי ייעוץ מקצועי, אתם לא יודעים אם ההצעה טובה או שאפשר להשיג יותר. אני כאן כדי לוודא שאתם מקבלים את מה שמגיע לכם."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="יש לכם שאלות על התחדשות עירונית?"
    subtitle="פגישת ייעוץ ראשונית ללא עלות - נעזור לכם להבין את האפשרויות שלכם"
    ctaText="קבעו פגישה"
  />

  <TestimonialSection />

  <FAQ
    title="שאלות נפוצות על התחדשות עירונית"
    items={faqItems}
  />

  <!-- Related Services -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-xl md:text-2xl font-bold text-dark mb-6 text-center">
          שירותים נוספים
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="/investor-consulting/" class="block p-6 bg-white rounded-xl border border-border hover:border-brand-300 transition-colors">
            <h3 class="font-semibold text-dark mb-2">ליווי משקיעים לרכישת דירה</h3>
            <p class="text-muted text-sm mb-2">מחפשים לקנות דירה בפרויקט התחדשות? ליווי מקיף מאיתור ועד חתימה.</p>
            <span class="text-brand-600 text-sm font-medium">לפרטים ←</span>
          </a>

          <a href="/apartment-investment-analysis/" class="block p-6 bg-white rounded-xl border border-border hover:border-brand-300 transition-colors">
            <h3 class="font-semibold text-dark mb-2">בדיקת כדאיות דירה להשקעה</h3>
