---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="תודה על פנייתכם"
  description="קיבלנו את פנייתכם ונחזור אליכם בהקדם"
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-16 md:py-24 bg-gradient-to-b from-brand-50 to-white">
    <div class="container mx-auto px-4">
      <div class="max-w-xl mx-auto text-center">
        <!-- Success Icon -->
        <div class="w-20 h-20 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-8">
          <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="font-heading text-3xl md:text-4xl font-bold text-dark mb-4">
          תודה על פנייתכם!
        </h1>

        <p class="text-lg text-muted mb-8">
          קיבלנו את הפרטים שלכם ונחזור אליכם בהקדם האפשרי, בדרך כלל תוך יום עסקים אחד.
        </p>

        <div class="space-y-4">
          <p class="text-muted">
            בינתיים, אתם מוזמנים להתקשר אלינו ישירות:
          </p>

          <!-- TODO: Add phone number link here -->
        </div>

        <div class="mt-12">
          <a
            href="/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white rounded-md font-semibold transition-colors"
          >
            <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            חזרה לדף הבית
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
