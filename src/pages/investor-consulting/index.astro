---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const faqItems = [
  {
    question: 'מה כולל שירות ליווי משקיעים לרכישת דירה?',
    answer: 'השירות כולל: ייעוץ ראשוני והגדרת מטרות, בניית פרופיל משקיע, ניתוח שוק וזיהוי הזדמנויות, סיורים בנכסים פוטנציאליים, <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות מקצועית</a> לכל נכס, ניהול משא ומתן, ליווי עד לחתימה וקבלת מפתח, וגישה לקבוצת וואטסאפ עם כל בעלי המקצוע.',
  },
  {
    question: 'מה זה מלווה משקיעים נדל״ן וכמה זה עולה?',
    answer: 'מלווה משקיעים נדל״ן הוא איש מקצוע שמלווה אתכם בכל תהליך רכישת דירה להשקעה — מהגדרת היעדים, דרך איתור הנכס ובדיקת הכדאיות, ועד לחתימה. העלות המקובלת בשוק: 30,000-35,000 ש״ח. אצלנו: 18,000 ש״ח מחיר קבוע (כולל מע״מ) — חיסכון של כ-50%.',
  },
  {
    question: 'מה ההבדל בין מלווה משקיעים ליועץ השקעות נדל״ן?',
    answer: 'בפועל, שני המונחים מתארים את אותו שירות. יועץ השקעות נדל״ן מתמקד יותר באסטרטגיה (לאן להשקיע, איזה סוג נכס, מה התשואה הצפויה), בעוד מלווה משקיעים מדגיש את הליווי המעשי (סיורים, משא ומתן, חתימה). אצלנו מקבלים את שניהם יחד — ייעוץ אסטרטגי + ליווי מעשי מקצה לקצה.',
  },
  {
    question: 'איך עושים בדיקת כדאיות לדירה להשקעה?',
    answer: 'בדיקת כדאיות מקצועית כוללת: הערכת שווי הנכס (שמאות), חישוב תשואה צפויה משכירות (ממוצע בישראל: 3-4%, אצלנו: 5-8%), ניתוח פוטנציאל עליית ערך, בדיקת עלויות נלוות (מס רכישה, עו״ד, שיפוץ), ובדיקת סיכונים (רישום, חובות, ליקויים). אנחנו מבצעים בדיקה מקיפה לכל נכס לפני שממליצים.',
  },
  {
    question: 'מה ההבדל בינכם לבין מתווך?',
    answer: 'מתווך מרוויח 1-2% מהעסקה - בדירה של מיליון ש״ח זה 10,000-20,000 ש״ח. יש לו אינטרס שתקנו נכס כלשהו ובמחיר גבוה. אנחנו גובים מחיר קבוע (18,000 ש״ח) והליווי מתבצע על ידי שמאית מקרקעין מוסמכת - האינטרס שלנו הוא שתעשו עסקה טובה, גם אם זה לוקח יותר זמן.',
  },
  {
    question: 'באילו סוגי נכסים אתם מתמחים?',
    answer: 'אנחנו מתמחים בדירות בהתחדשות עירונית (פינוי-בינוי, תמ״א 38), דירות על הנייר (פריסייל 15/85), דירות יד שנייה עם פוטנציאל השבחה, ונכסים למשפרי דיור. ההתמחות שלנו היא באזור חיפה, הקריות וקו החוף הצפוני, אך אנחנו פועלים גם במרכז הארץ.',
  },
  {
    question: 'כמה זמן לוקח למצוא נכס מתאים?',
    answer: 'בממוצע 2-4 חודשים. הזמן תלוי בדרישות שלכם, בתקציב ובהיצע בשוק. אנחנו לא ממהרים - עדיף לחכות לנכס הנכון מאשר לרכוש נכס בינוני. יש לקוחות שמצאנו להם עסקה תוך 3 שבועות, ויש שלקח 6 חודשים.',
  },
  {
    question: 'מה קורה אחרי החתימה על העסקה?',
    answer: 'הליווי לא נגמר בחתימה. אנחנו עומדים מאחורי הלקוחות שלנו גם שנים קדימה - עוזרים בתיאום שיפוצים, מציאת שוכרים, ייעוץ לגבי מכירה עתידית. קבוצת הוואטסאפ נשארת פתוחה לכל שאלה.',
  },
  {
    question: 'האם המקדמה מוחזרת אם לא מצאתם לי נכס?',
    answer: 'המקדמה של 5,000 ש״ח לא מוחזרת במקרה של נסיגה מצד הלקוח, כי היא משקפת עבודת ייעוץ, ניתוח ועבודת שטח שכבר בוצעו. עם זאת, אנחנו ממשיכים לחפש עד שמוצאים את הנכס המתאים - אין מגבלת זמן.',
  },
  {
    question: 'באיזה אזורים אתם פועלים?',
    answer: 'ההתמחות העיקרית שלנו היא בצפון: <a href="/areas/haifa/" class="text-brand-600 hover:underline">חיפה</a>, הקריות (קריית חיים, קריית ביאליק, קריית מוצקין), נשר, טירת הכרמל, עכו ונהריה. אנחנו פועלים גם במרכז: <a href="/areas/netanya/" class="text-brand-600 hover:underline">נתניה</a>, <a href="/areas/rishon/" class="text-brand-600 hover:underline">ראשון לציון</a>, <a href="/areas/givat-shmuel/" class="text-brand-600 hover:underline">גבעת שמואל</a> ופתח תקווה. <a href="/areas/" class="text-brand-600 hover:underline">לכל אזורי הפעילות ←</a>',
  },
];

const serviceSteps = [
  { number: 1, title: 'פגישת היכרות', description: 'הבנת הצרכים, היעדים והתקציב. בניית פרופיל משקיע אישי.' },
  { number: 2, title: 'ניתוח שוק', description: 'מחקר מעמיק של השוק, זיהוי אזורים חמים והזדמנויות.' },
  { number: 3, title: 'סיורים ובדיקות', description: 'ביקור בנכסים, בדיקת כדאיות מקצועית וניתוח השוואתי.' },
  { number: 4, title: 'סגירת עסקה', description: 'משא ומתן, ליווי משפטי ועד לחתימה וקבלת מפתח.' },
];

// Case studies data
const caseStudies = [
  {
    title: 'דירה בהתחדשות עירונית - קריית חיים',
    description: 'ליווינו משקיע לדירה ברחוב טרומן. לאחר 3 שנים, עם קבלת היתר דיפון וחפירה',
    result: '323,000 ש״ח',
    resultLabel: 'עליית ערך',
  },
  {
    title: 'דירה בקריית שפרינצק, חיפה',
    description: 'איתרנו דירה חתומה על פינוי-בינוי, עם תשואה נאה משכירות',
    result: '167,000 ש״ח',
    resultLabel: 'מתחת למחיר השוק',
  },
  {
    title: 'פריסייל במרכז הארץ',
    description: 'ליווינו לקוח להשקעת דירה על הנייר. לאחר 3 שנים',
    result: '380,000 ש״ח',
    resultLabel: 'עליית ערך',
  },
  {
    title: 'התחדשות עירונית - נשר',
    description: 'דירה ליד הטכניון המשלבת תשואה גבוהה משכירות ועליית ערך. בתהליכי מכירה',
    result: '410,000 ש״ח',
    resultLabel: 'רווח על הנייר',
  },
];

// Service schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'מלווה משקיעים נדל״ן - ליווי לרכישת דירה להשקעה',
  description: 'שירות ליווי משקיעים מקצועי עם שמאית מקרקעין מוסמכת ויועץ השקעות נדל״ן. כולל בדיקת כדאיות השקעה, ניתוח תשואה, משא ומתן וליווי עד חתימה. מחיר קבוע 18,000 ש״ח - חצי ממחיר המתחרים.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
    telephone: '+972-55-255-5144',
  },
  areaServed: ['חיפה', 'קריות', 'נשר', 'נתניה', 'ראשון לציון', 'גבעת שמואל'],
  serviceType: 'ליווי השקעות נדל״ן',
  offers: {
    '@type': 'Offer',
    price: '18000',
    priceCurrency: 'ILS',
    description: 'ליווי מקיף מקצה לקצה',
  },
};
---

<BaseLayout
  title="ליווי משקיעים נדל״ן | מלווה משקיעים מקצועי - 18,000₪ מחיר קבוע"
  description="מלווה משקיעים ויועץ השקעות נדל״ן עם שמאית מקרקעין מוסמכת. ליווי מקיף לרכישת דירה להשקעה: בדיקת כדאיות, משא ומתן, עד לחתימה. 18,000₪ קבוע - חצי ממחיר המתחרים."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="ליווי משקיעים לרכישת דירה להשקעה"
    subtitle="מלווה משקיעים מקצועי עם שמאית מקרקעין מוסמכת ויועץ השקעות נדל״ן. בדיקת כדאיות מקיפה, ניתוח תשואה על הדירה, משא ומתן וליווי עד החתימה. 18,000₪ מחיר קבוע - ללא ניגוד אינטרסים."
    backgroundImage="/images/hero/hero-01.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ חינם"
  />

  <TrustBar variant="light" />

  <!-- Intro Section - Semantic Keywords -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <p class="text-muted leading-relaxed">
          <strong>מלווה משקיעים נדל״ן</strong> הוא אנשי מקצוע שמלווה אתכם בכל תהליך רכישת דירה להשקעה —
          מבדיקת כדאיות ההשקעה הראשונית ועד לחתימה על החוזה וקבלת המפתח.
          בניגוד למתווך שמרוויח אחוזים מהעסקה, <strong>יועץ השקעות נדל״ן</strong> עובד בתשלום קבוע
          ולכן האינטרס שלו הוא שתעשו את העסקה הטובה ביותר — גם אם זה לוקח יותר זמן.
        </p>
        <p class="text-muted leading-relaxed">
          אצלנו, הליווי מתבצע על ידי <strong>שמאית מקרקעין מוסמכת</strong> עם 15 שנות ניסיון
          ויועץ משקיעים עם רקע בהייטק. השילוב הזה מאפשר <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות מקצועית</a>
          שכוללת הערכת שווי מדויקת, ניתוח תשואה צפויה (ממוצע של 13% בשנה אצל לקוחותינו),
          וזיהוי סיכונים לפני שמתחייבים. העלות: <strong>18,000 ש״ח</strong> — כמחצית מהמחיר המקובל בשוק (30,000-35,000 ש״ח).
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Section - Key Numbers -->
  <section class="py-12 bg-brand-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">617+</div>
            <div class="text-sm text-muted">בדיקות עסקה וייעוצים</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">98+</div>
            <div class="text-sm text-muted">משקיעים מרוצים</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">13%</div>
            <div class="text-sm text-muted">תשואה שנתית ממוצעת</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">15</div>
            <div class="text-sm text-muted">שנות ניסיון בנדל״ן</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies - Real Results -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
            630,000 ש״ח חיסכון ב-4 עסקאות בלבד
          </h2>
          <p class="text-muted max-w-2xl mx-auto">
            ההבדל בין לחפש לבד לבין ליווי מקצועי - לא רק הידע והניסיון, אלא חיסכון של עשרות אלפי שקלים שהופכים לרווח יותר גדול בהמשך הדרך.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {caseStudies.map((study) => (
            <div class="p-6 bg-surface rounded-xl border border-border hover:border-brand-200 transition-colors">
              <h3 class="font-semibold text-dark mb-2">{study.title}</h3>
              <p class="text-muted text-sm mb-4">{study.description}</p>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-success-600">{study.result}</span>
                <span class="text-sm text-muted">{study.resultLabel}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What's Different - Key Differentiators -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה שונה בליווי משקיעים נדל״ן שלנו?
        </h2>

        <div class="space-y-6">
          <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">מעין ואור מלווים אתכם אישית - ללא שליחים</h3>
              <p class="text-muted">אין עוזרים, נציגים וסגנים. כל הליווי מתבצע מולנו ישירות, בגובה העיניים, בצורה מקצועית ואישית. אתם לא "עוד לקוח במערכת".</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">שילוב נדיר: שמאית מקרקעין + רקע הייטק</h3>
              <p class="text-muted">מעין - שמאית מקרקעין מוסמכת עם 15 שנות ניסיון. אור - מלווה משקיעים עם 12 שנים בנדל״ן ו-8 שנים בהייטק (כולל אקזיט עם גרניולט שנמכרה לאינטל). הידע המשולב מאפשר ניתוח עסקאות ברמה שאי אפשר למצוא במקום אחר.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">מחיר קבוע = אפס ניגוד אינטרסים</h3>
              <p class="text-muted">מתווך מרוויח 1-2% מהעסקה, אז יש לו אינטרס שתקנו כמה שיותר יקר. אנחנו גובים 18,000 ש״ח קבוע - לא משנה אם הדירה עולה 800,000 או 2,000,000. האינטרס שלנו: שתעשו את העסקה הכי טובה.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">קבוצת וואטסאפ עם כל בעלי המקצוע</h3>
