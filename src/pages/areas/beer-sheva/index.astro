---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import TrustBar from '../../../components/TrustBar.astro';
import ServicesGrid from '../../../components/ServicesGrid.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactForm from '../../../components/ContactForm.astro';
import CTASection from '../../../components/CTASection.astro';
import SchemaOrg from '../../../components/SchemaOrg.astro';

const faqItems = [
  {
    question: 'למה באר שבע נחשבת להזדמנות השקעה?',
    answer: 'באר שבע מציעה תשואות מהגבוהות בישראל (5-6%+) עם מחירי כניסה נמוכים (700K-1.3M). העיר צומחת בזכות אוניברסיטת בן גוריון, בסיסי צה"ל שעוברים לדרום, ופארק ההייטק החדש.',
  },
  {
    question: 'מי השוכרים הטיפוסיים בבאר שבע?',
    answer: 'סטודנטים מאוניברסיטת בן גוריון (22,000+ סטודנטים), חיילים ואנשי קבע, עובדי ההייטק בפארק החדש, ומשפחות מקומיות. ביקוש קבוע לאורך כל השנה.',
  },
  {
    question: 'מה הסיכונים בהשקעה בבאר שבע?',
    answer: 'המרחק מהמרכז (שעה מת"א), תנודות באוכלוסייה (סטודנטים עוזבים בקיץ), ותדמית שלא תמיד מדויקת. אבל מי שמכיר את השוק יודע שהתשואות מפצות על הסיכונים.',
  },
  {
    question: 'אילו שכונות מומלצות?',
    answer: 'שכונה ד\' ליד האוניברסיטה לתשואה מקסימלית. רמות ונווה זאב למשפחות ויציבות. עיר העתיקה לפוטנציאל התחדשות.',
  },
  {
    question: 'כמה עולה ליווי משקיעים בבאר שבע?',
    answer: 'המחירים שלנו קבועים ללא קשר לאזור: <a href="/investor-consulting/" class="text-brand-600 hover:underline">ליווי משקיעים לרכישת דירה</a> - 18,000 ש״ח, <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות דירה</a> - 1,800 ש״ח.',
  },
];

const marketStats = [
  { label: 'מחיר ממוצע לדירה 3 חד\'', value: '800K-1.3M ש״ח' },
  { label: 'תשואה ממוצעת', value: '5-7%' },
  { label: 'שכירות ממוצעת', value: '3,000-4,500 ש״ח' },
  { label: 'סטודנטים', value: '22,000+' },
];

const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'ליווי משקיעי נדל״ן בבאר שבע - מעין ואור ליבנה',
  description: 'ליווי משקיעי נדל״ן בבאר שבע. עיר אוניברסיטאית, תשואות גבוהות 5-7%, מחירים נגישים.',
  url: 'https://hashkaot-nadlan.co.il/areas/beer-sheva/',
  telephone: '+972-55-2555144',
  areaServed: { '@type': 'City', name: 'באר שבע' },
  priceRange: '₪',
};
---

<BaseLayout
  title="ליווי משקיעי נדל״ן בבאר שבע - תשואות גבוהות"
  description="ליווי משקיעי נדל״ן בבאר שבע - עיר אוניברסיטאית עם תשואות 5-7%. מחירים נגישים (800K-1.3M), ביקוש קבוע מסטודנטים וצבא. שמאית מקרקעין מוסמכת. צרו קשר."
>
  <SchemaOrg schema={localSchema} />

  <PageHero
    title="ליווי משקיעי נדל״ן בבאר שבע"
    subtitle="באר שבע היא עיר אוניברסיטאית צומחת עם תשואות מהגבוהות בישראל. 22,000+ סטודנטים, בסיסי צה״ל, ופארק הייטק חדש - ביקוש קבוע לשכירות."
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ"
  />

  <TrustBar variant="light" />

  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          שוק הנדל״ן בבאר שבע - 2026
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          {marketStats.map((stat) => (
            <div class="bg-brand-50 rounded-xl p-4 text-center">
              <div class="text-lg md:text-xl font-bold text-brand-600 mb-1">{stat.value}</div>
              <div class="text-sm text-muted">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="prose prose-lg max-w-none text-muted">
          <p>
            באר שבע עוברת טרנספורמציה - מ"בירת הנגב" לעיר הייטק וסטודנטים. אוניברסיטת בן גוריון היא אחת הגדולות בישראל עם למעלה מ-22,000 סטודנטים, וכולם צריכים דירות.
          </p>
          <p>
            בנוסף, המעבר של בסיסי צה"ל לנגב מביא אלפי משפחות חדשות, ופארק ההייטק "גב-ים נגב" מושך חברות הייטק ועובדים. התוצאה: ביקוש גבוה לשכירות ותשואות מהגבוהות בישראל.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          שכונות בבאר שבע
        </h2>

        <div class="space-y-6">
          {[
            {
              name: 'שכונה ד\' (ליד האוניברסיטה)',
              profile: 'סטודנטים + תשואה',
              price: '700K-1M ש״ח',
              yield: '6-7%',
              desc: 'צמוד לאוניברסיטה = ביקוש קבוע מסטודנטים. תשואות גבוהות מאוד. חסרון: תחלופה גבוהה (סטודנטים עוזבים), ותקופת קיץ שקטה יותר.',
              highlight: 'יתרון: תשואה מקסימלית',
            },
            {
              name: 'רמות',
              profile: 'משפחות + יציבות',
              price: '1-1.5M ש״ח',
              yield: '4.5-5.5%',
              desc: 'שכונה משפחתית ותיקה עם שוכרים יציבים יותר. מחירים מעט גבוהים יותר אך פחות תחלופה. בתי ספר טובים, מסחר.',
              highlight: 'יתרון: יציבות, פחות תחלופה',
            },
            {
              name: 'נווה זאב',
              profile: 'חדש + איכותי',
              price: '1.2-1.8M ש״ח',
              yield: '4-5%',
              desc: 'השכונה החדשה והמבוקשת. דירות חדשות, תשתיות מודרניות. מחירים גבוהים יחסית לבאר שבע אך שוכרים איכותיים.',
              highlight: 'יתרון: דירות חדשות, שוכרים איכותיים',
            },
            {
              name: 'עיר עתיקה ומרכז',
              profile: 'התחדשות עירונית',
              price: '600K-900K ש״ח',
              yield: '5-6%',
              desc: 'מחירי הכניסה הנמוכים ביותר עם פוטנציאל התחדשות. דורש יותר מחקר ובדיקה - יש אזורים טובים ופחות טובים.',
              highlight: 'יתרון: מחיר נמוך מאוד',
            },
          ].map((neighborhood) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                <div>
                  <h3 class="font-heading font-bold text-dark text-xl">{neighborhood.name}</h3>
                  <span class="inline-block px-3 py-1 bg-brand-100 text-brand-600 rounded-full text-sm">
                    {neighborhood.profile}
                  </span>
                </div>
                <div class="flex gap-6 text-sm">
                  <div>
                    <span class="text-muted">מחיר: </span>
                    <span class="font-semibold text-dark">{neighborhood.price}</span>
                  </div>
                  <div>
                    <span class="text-muted">תשואה: </span>
                    <span class="font-semibold text-accent">{neighborhood.yield}</span>
                  </div>
                </div>
              </div>
              <p class="text-muted mb-3">{neighborhood.desc}</p>
              <p class="text-sm text-brand-600 font-medium">{neighborhood.highlight}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- University Proximity Highlight -->
  <section class="py-16 md:py-20 bg-brand-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-6">
          יתרון האוניברסיטה
        </h2>
        <p class="text-lg text-muted mb-8">
          אוניברסיטת בן גוריון היא מנוע הצמיחה של באר שבע - 22,000+ סטודנטים שצריכים דיור:
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-5">
            <div class="text-2xl font-bold text-brand-600 mb-2">22,000+</div>
            <div class="text-sm text-muted">סטודנטים פעילים</div>
          </div>
          <div class="bg-white rounded-xl p-5">
            <div class="text-2xl font-bold text-brand-600 mb-2">10 חודש</div>
            <div class="text-sm text-muted">שנת לימודים פעילה</div>
          </div>
          <div class="bg-white rounded-xl p-5">
            <div class="text-2xl font-bold text-brand-600 mb-2">ביקוש עולה</div>
            <div class="text-sm text-muted">האוניברסיטה צומחת</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="השירותים שלנו בבאר שבע"
    subtitle="כל השירותים שלנו זמינים באזור באר שבע - ליווי מלא או בדיקות נקודתיות"
  />

  <CTASection
    title="מחפשים השקעה בבאר שבע?"
    subtitle="נעזור לכם להבין את שוק הדרום"
    ctaText="השאירו פרטים"
  />

  <FAQ
    title="שאלות נפוצות על השקעות בבאר שבע"
    items={faqItems}
  />

  <ContactForm
    title="מעוניינים בייעוץ לאזור באר שבע?"
    subtitle="השאירו פרטים ונחזור אליכם בהקדם"
  />
</BaseLayout>
