---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import TrustBar from '../../../components/TrustBar.astro';
import ServicesGrid from '../../../components/ServicesGrid.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactForm from '../../../components/ContactForm.astro';
import CTASection from '../../../components/CTASection.astro';
import SchemaOrg from '../../../components/SchemaOrg.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'אזורי שירות', href: '/areas/' },
  { label: 'ראשון לציון' },
];

const faqItems = [
  {
    question: 'למה להשקיע בנדל״ן בראשון לציון?',
    answer: 'ראשון לציון היא העיר הרביעית בגודלה בישראל עם ביקוש גבוה ויציב לדירות. הקרבה לתל אביב, תשתיות מפותחות (רכבת קלה, קניונים) ואוכלוסייה צעירה הופכים אותה לאטרקטיבית להשקעה.',
  },
  {
    question: 'מה התשואה הממוצעת בראשון לציון?',
    answer: 'התשואה הממוצעת נעה בין 3% ל-4.5% ברוטו, תלוי בשכונה. שכונות כמו נחלת יהודה ורמת אליהו מציעות תשואות גבוהות יותר.',
  },
  {
    question: 'האם יש פרויקטי התחדשות עירונית בראשון?',
    answer: 'כן, ראשון לציון נמצאת במרכז מהפכת ההתחדשות העירונית. מאות פרויקטים מתוכננים ומאושרים, בעיקר במרכז העיר ובשכונות הוותיקות. <a href="/urban-renewal/" class="text-brand-600 hover:underline">ראו את שירות ייעוץ התחדשות עירונית ←</a>',
  },
  {
    question: 'כמה עולה ליווי משקיעים בראשון לציון?',
    answer: 'מחירים קבועים: <a href="/investor-consulting/" class="text-brand-600 hover:underline">ליווי משקיעים</a> - 18,000 ש״ח, <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות דירה</a> - 1,800 ש״ח.',
  },
];

const marketStats = [
  { label: 'מחיר ממוצע לדירה 3 חד\'', value: '2-2.8M ש״ח' },
  { label: 'תשואה ממוצעת', value: '3-4.5%' },
  { label: 'שכירות ממוצעת', value: '4,500-6,500 ש״ח' },
  { label: 'אוכלוסייה', value: '260K+' },
];

const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'ליווי משקיעי נדל״ן בראשון לציון - מעין ואור ליבנה',
  description: 'ליווי משקיעי נדל״ן בראשון לציון על ידי שמאית מקרקעין מוסמכת. בדיקות נכסים, ניתוח כדאיות וליווי עד לסגירת העסקה.',
  url: 'https://hashkaot-nadlan.co.il/areas/rishon/',
  telephone: '+972-55-2555144',
  areaServed: {
    '@type': 'City',
    name: 'ראשון לציון',
  },
};
---

<BaseLayout
  title="ליווי משקיעי נדל״ן בראשון לציון"
  description="ליווי משקיעי נדל״ן בראשון לציון - שמאית מקרקעין מוסמכת. בדיקות נכסים, ניתוח כדאיות. העיר הרביעית בישראל עם ביקוש גבוה. צרו קשר."
>
  <SchemaOrg schema={localSchema} />

  <PageHero
    title="ליווי משקיעי נדל״ן בראשון לציון"
    subtitle="ראשון לציון - העיר הרביעית בגודלה עם ביקוש יציב ותשתיות מתקדמות. נעזור לכם למצוא את ההשקעה הנכונה באחת הערים הצומחות ביותר במרכז."
    breadcrumbs={breadcrumbs}
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ"
  />

  <TrustBar variant="light" />

  <!-- Market Overview -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          שוק הנדל״ן בראשון לציון - 2026
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          {marketStats.map((stat) => (
            <div class="bg-brand-50 rounded-xl p-4 text-center">
              <div class="text-lg md:text-xl font-bold text-brand-600 mb-1">{stat.value}</div>
              <div class="text-sm text-muted">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="prose prose-lg max-w-none text-muted">
          <p>
            ראשון לציון היא עיר בצמיחה מתמדת, עם ביקוש גבוה לדירות הן מצעירים והן ממשפחות. הרכבת הקלה, הקניונים החדשים והקרבה לתל אביב הופכים אותה לאחת הערים האטרקטיביות ביותר במרכז.
          </p>
          <p>
            המחירים בראשון נמוכים ב-20-30% מתל אביב, מה שמאפשר נקודת כניסה נוחה יותר למשקיעים. במקביל, הביקוש היציב מבטיח שתמיד יהיו שוכרים.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhoods -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          שכונות מומלצות להשקעה
        </h2>

        <div class="space-y-6">
          {[
            {
              name: 'נחלת יהודה',
              profile: 'תשואה גבוהה',
              price: '1.5-2M ש״ח',
              yield: '4-5%',
              desc: 'שכונה ותיקה עם מחירי כניסה נוחים. ביקוש קבוע מסטודנטים וצעירים. תשואות גבוהות יחסית למרכז.',
            },
            {
              name: 'רמת אליהו',
              profile: 'התחדשות עירונית',
              price: '1.3-1.8M ש״ח',
              yield: '4.5-5.5%',
              desc: 'שכונה בהתחדשות מואצת עם עשרות פרויקטים. מחירי כניסה נמוכים ופוטנציאל השבחה משמעותי.',
            },
            {
              name: 'נאות אשלים',
              profile: 'יציבות',
              price: '2.3-3M ש״ח',
              yield: '3-3.5%',
              desc: 'שכונה חדשה ומבוקשת. מושכת משפחות צעירות. תשואה נמוכה יותר אך יציבות גבוהה ופוטנציאל עליית ערך.',
            },
            {
              name: 'מרכז העיר',
              profile: 'מיקום מרכזי',
              price: '1.8-2.5M ש״ח',
              yield: '3.5-4.5%',
              desc: 'קרבה לרכבת קלה, לקניונים ולתחבורה. ביקוש קבוע מכל סוגי האוכלוסייה. איזון טוב בין מיקום לתשואה.',
            },
          ].map((neighborhood) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                <div>
                  <h3 class="font-heading font-bold text-dark text-xl">{neighborhood.name}</h3>
                  <span class="inline-block px-3 py-1 bg-brand-100 text-brand-600 rounded-full text-sm">
                    {neighborhood.profile}
                  </span>
                </div>
                <div class="flex gap-6 text-sm">
                  <div>
                    <span class="text-muted">מחיר: </span>
                    <span class="font-semibold text-dark">{neighborhood.price}</span>
                  </div>
                  <div>
                    <span class="text-muted">תשואה: </span>
                    <span class="font-semibold text-accent">{neighborhood.yield}</span>
                  </div>
                </div>
              </div>
              <p class="text-muted">{neighborhood.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="השירותים שלנו בראשון לציון"
    subtitle="כל השירותים שלנו זמינים בראשון לציון והסביבה"
  />

  <CTASection
    title="מחפשים השקעה בראשון לציון?"
    subtitle="נעזור לכם למצוא את הנכס הנכון בעיר הצומחת ביותר במרכז"
    ctaText="השאירו פרטים"
  />

  <FAQ
    title="שאלות נפוצות על השקעות בראשון לציון"
    items={faqItems}
  />

  <ContactForm
    title="מעוניינים בייעוץ לאזור ראשון לציון?"
    subtitle="השאירו פרטים ונחזור אליכם בהקדם"
  />
</BaseLayout>
