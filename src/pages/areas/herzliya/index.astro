---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import TrustBar from '../../../components/TrustBar.astro';
import ServicesGrid from '../../../components/ServicesGrid.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactForm from '../../../components/ContactForm.astro';
import CTASection from '../../../components/CTASection.astro';
import SchemaOrg from '../../../components/SchemaOrg.astro';

const faqItems = [
  {
    question: 'האם הרצליה מתאימה למשקיעים?',
    answer: 'הרצליה היא שוק פרימיום - מחירים גבוהים (2.5M-5M+) עם תשואות נמוכות (2.5-3.5%). היא מתאימה למשקיעים שמחפשים יציבות מקסימלית, שוכרים איכותיים, ועליית ערך לטווח ארוך. פחות מתאימה למי שמחפש תשואה שוטפת.',
  },
  {
    question: 'מה ההבדל בין הרצליה פיתוח להרצליה העירונית?',
    answer: 'הרצליה פיתוח היא היוקרתית ביותר - וילות ופנטהאוזים, מחירים של מיליונים. הרצליה העירונית נגישה יותר עם דירות רגילות. הרצליה הצעירה ורמת השרון מציעות מחירים נוחים יותר באותו אזור.',
  },
  {
    question: 'מי השוכרים הטיפוסיים בהרצליה?',
    answer: 'אנשי הייטק בכירים (מרכז ההייטק בהרצליה פיתוח), משפחות מבוססות, אנשי עסקים, ודיפלומטים. שוכרים איכותיים שמשלמים בזמן ושומרים על הנכס.',
  },
  {
    question: 'יש עסקאות קרקע בהרצליה?',
    answer: 'כן, אבל במחירים גבוהים מאוד. עסקאות קרקע בהרצליה מתאימות למשקיעים מתוחכמים עם הון גבוה. <a href="/land-deal-assessment/" class="text-brand-600 hover:underline">ראו את שירות בדיקת עסקת קרקע שלנו ←</a>',
  },
  {
    question: 'כמה עולה ליווי משקיעים בהרצליה?',
    answer: 'המחירים שלנו קבועים ללא קשר לאזור: <a href="/investor-consulting/" class="text-brand-600 hover:underline">ליווי משקיעים לרכישת דירה</a> - 18,000 ש״ח, <a href="/apartment-investment-analysis/" class="text-brand-600 hover:underline">בדיקת כדאיות דירה</a> - 1,800 ש״ח.',
  },
];

const marketStats = [
  { label: 'מחיר ממוצע לדירה 4 חד\'', value: '3-5M ש״ח' },
  { label: 'תשואה ממוצעת', value: '2.5-3.5%' },
  { label: 'שכירות ממוצעת', value: '8,000-15,000 ש״ח' },
  { label: 'סוג שוק', value: 'פרימיום' },
];

const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'ליווי משקיעי נדל״ן בהרצליה - מעין ואור ליבנה',
  description: 'ליווי משקיעי נדל״ן בהרצליה. שוק פרימיום, שוכרים איכותיים, עסקאות קרקע.',
  url: 'https://hashkaot-nadlan.co.il/areas/herzliya/',
  telephone: '+972-55-2555144',
  areaServed: { '@type': 'City', name: 'הרצליה' },
  priceRange: '₪₪₪',
};
---

<BaseLayout
  title="ליווי משקיעי נדל״ן בהרצליה - שוק פרימיום"
  description="ליווי משקיעי נדל״ן בהרצליה - שוק פרימיום עם שוכרים איכותיים. מחירים 3-5M+, תשואה 2.5-3.5%, עסקאות קרקע. שמאית מקרקעין מוסמכת. צרו קשר."
>
  <SchemaOrg schema={localSchema} />

  <PageHero
    title="ליווי משקיעי נדל״ן בהרצליה"
    subtitle="הרצליה היא שוק הפרימיום של ישראל - מחירים גבוהים אך יציבות מקסימלית, שוכרים איכותיים, ועליית ערך יציבה לאורך שנים. למשקיעים מתוחכמים."
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ"
  />

  <TrustBar variant="light" />

  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          שוק הנדל״ן בהרצליה - 2026
        </h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          {marketStats.map((stat) => (
            <div class="bg-brand-50 rounded-xl p-4 text-center">
              <div class="text-lg md:text-xl font-bold text-brand-600 mb-1">{stat.value}</div>
              <div class="text-sm text-muted">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="prose prose-lg max-w-none text-muted">
          <p>
            הרצליה היא אחד משווקי הנדל"ן היוקרתיים ביותר בישראל. המחירים כאן גבוהים - ממוצע של 3-5 מיליון לדירת 4 חדרים - אבל התמורה היא יציבות מקסימלית ושוכרים מהשורה הראשונה.
          </p>
          <p>
            הרצליה פיתוח היא מרכז ההייטק הגדול בישראל עם חברות כמו מיקרוסופט, גוגל, ואפל. אלפי אנשי הייטק בכירים מחפשים דירות לשכירות באזור - מה שמבטיח ביקוש קבוע ושוכרים איכותיים.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          אזורים בהרצליה
        </h2>

        <div class="space-y-6">
          {[
            {
              name: 'הרצליה פיתוח',
              profile: 'סופר-פרימיום',
              price: '5M+ ש״ח',
              yield: '2-2.5%',
              desc: 'השכונה היוקרתית ביותר. וילות, פנטהאוזים, קו ראשון לים. מחירים של מיליונים רבים. מתאים למשקיעים עם הון משמעותי שמחפשים שימור ערך ויוקרה.',
              highlight: 'יתרון: יוקרה, יציבות מקסימלית',
            },
            {
              name: 'הרצליה הצעירה',
              profile: 'נגיש יותר',
              price: '2.5-4M ש״ח',
              yield: '3-3.5%',
              desc: 'דירות חדשות ומודרניות במחירים נוחים יותר (יחסית להרצליה). ביקוש גבוה מזוגות צעירים ומשפחות. איזון טוב בין יוקרה לתשואה.',
              highlight: 'יתרון: נגיש יותר, ביקוש גבוה',
            },
            {
              name: 'מרכז הרצליה',
              profile: 'עירוני + שירותים',
              price: '2.5-3.5M ש״ח',
              yield: '3-3.5%',
              desc: 'קרוב לשירותים, חנויות, מסעדות. דירות מגוונות - ישנות וחדשות. פחות יוקרתי מפיתוח אך עדיין שוק איכותי.',
              highlight: 'יתרון: מיקום מרכזי, שירותים',
            },
            {
              name: 'רמת השרון (סמוך)',
              profile: 'אלטרנטיבה נגישה',
              price: '2-3M ש״ח',
              yield: '3-4%',
              desc: 'עיר שכנה עם מחירים נמוכים יותר אך אותו אזור. משפחתית, שקטה, בתי ספר טובים. אלטרנטיבה טובה למי שרוצה את האזור בתקציב נמוך יותר.',
              highlight: 'יתרון: מחירים נגישים יותר',
            },
          ].map((neighborhood) => (
            <div class="bg-white rounded-xl p-6 border border-border">
              <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                <div>
                  <h3 class="font-heading font-bold text-dark text-xl">{neighborhood.name}</h3>
                  <span class="inline-block px-3 py-1 bg-brand-100 text-brand-600 rounded-full text-sm">
                    {neighborhood.profile}
                  </span>
                </div>
                <div class="flex gap-6 text-sm">
                  <div>
                    <span class="text-muted">מחיר: </span>
                    <span class="font-semibold text-dark">{neighborhood.price}</span>
                  </div>
                  <div>
                    <span class="text-muted">תשואה: </span>
                    <span class="font-semibold text-accent">{neighborhood.yield}</span>
                  </div>
                </div>
              </div>
              <p class="text-muted mb-3">{neighborhood.desc}</p>
              <p class="text-sm text-brand-600 font-medium">{neighborhood.highlight}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid
    title="השירותים שלנו בהרצליה"
    subtitle="כל השירותים שלנו זמינים באזור הרצליה - ליווי מלא או בדיקות נקודתיות"
  />

  <CTASection
    title="מחפשים השקעה בהרצליה?"
    subtitle="נעזור לכם להבין את השוק הפרימיום"
    ctaText="השאירו פרטים"
  />

  <FAQ
    title="שאלות נפוצות על השקעות בהרצליה"
    items={faqItems}
  />

  <ContactForm
    title="מעוניינים בייעוץ לאזור הרצליה?"
    subtitle="השאירו פרטים ונחזור אליכם בהקדם"
  />
</BaseLayout>
