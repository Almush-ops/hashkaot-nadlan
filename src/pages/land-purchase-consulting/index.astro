---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';


const faqItems = [
  {
    question: 'מה ההבדל בין ליווי רכישת קרקע לבדיקת עסקת קרקע?',
    answer: '<a href="/land-deal-assessment/" class="text-brand-600 hover:underline">בדיקת עסקת קרקע</a> היא בדיקה חד-פעמית לקרקע ספציפית (2,500 ש״ח). ליווי רכישת קרקע הוא שירות מקיף שכולל איתור קרקעות מתאימות, בדיקות מרובות, ניהול משא ומתן וליווי עד לחתימה.',
  },
  {
    question: 'כמה עולה ליווי רכישת קרקע?',
    answer: 'עלות הליווי המלא היא 15,000 ש״ח. המחיר כולל איתור, בדיקות מרובות, ניהול משא ומתן וליווי עד לסגירת העסקה. זה מחיר קבוע - ללא אחוזים מהעסקה.',
  },
  {
    question: 'איזה סוגי קרקעות אתם מלווים?',
    answer: 'אנחנו מלווים ברכישת כל סוגי הקרקעות: קרקע למגורים (מגרשים בפרצלציה), קרקע חקלאית עם פוטנציאל שינוי ייעוד, קרקע מסחרית, ומתחמים לפינוי-בינוי. ההתמחות שלנו היא בזיהוי קרקעות עם פוטנציאל השבחה.',
  },
  {
    question: 'כמה זמן לוקח למצוא קרקע מתאימה?',
    answer: 'בממוצע 3-6 חודשים, תלוי בדרישות ובתקציב. קרקעות איכותיות עם פוטנציאל אמיתי דורשות סבלנות וחיפוש מעמיק. אנחנו לא ממהרים לסגור - עדיף להמתין לעסקה הנכונה.',
  },
  {
    question: 'האם אתם עובדים עם עורכי דין ושמאים?',
    answer: 'כן, מעיין היא שמאית מקרקעין מוסמכת עם 15 שנות ניסיון. אנחנו עובדים בשיתוף פעולה עם עורכי דין מומחים בנדל״ן ומקרקעין כדי להבטיח עסקה בטוחה מכל הבחינות.',
  },
  {
    question: 'מה הסיכונים ברכישת קרקע ללא ליווי?',
    answer: 'הסיכונים כוללים: רכישת קרקע ללא זכויות בנייה ברורות, בעיות רישום ובעלות, היטלי השבחה לא צפויים, קרקע חקלאית ללא סיכוי לשינוי ייעוד, ותשלום מחיר מופרז. ליווי מקצועי חוסך לכם מאות אלפי שקלים של טעויות.',
  },
  {
    question: 'באיזה אזורים אתם פועלים?',
    answer: 'אנחנו פועלים בכל הארץ, עם התמחות מיוחדת בצפון (חיפה, קריות, עכו, נהריה) ובמרכז (נתניה, ראשון לציון, גבעת שמואל, פתח תקווה). יש לנו רשת קשרים רחבה עם בעלי קרקעות באזורים אלה.',
  },
  {
    question: 'מה קורה אם לא מצאתם לי קרקע מתאימה?',
    answer: 'אנחנו ממשיכים לחפש עד שמוצאים. אין מגבלת זמן על השירות. עם זאת, אם מסיבה כלשהי תחליטו להפסיק את הליווי, תשלמו רק על העבודה שבוצעה עד אותו שלב.',
  },
];

const serviceSteps = [
  { number: 1, title: 'הגדרת צרכים', description: 'פגישת היכרות להבנת היעדים, התקציב וסוג הקרקע המבוקש.' },
  { number: 2, title: 'איתור קרקעות', description: 'חיפוש מעמיק וסינון ראשוני של קרקעות פוטנציאליות.' },
  { number: 3, title: 'בדיקות מקיפות', description: 'בדיקה תכנונית, משפטית וכלכלית לכל קרקע רלוונטית.' },
  { number: 4, title: 'משא ומתן וסגירה', description: 'ניהול המשא ומתן וליווי עד לחתימת החוזה.' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ליווי רכישת קרקע',
  description: 'ליווי מקיף לרכישת קרקע להשקעה - מאיתור ועד סגירת העסקה',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
  areaServed: 'ישראל',
  serviceType: 'ליווי השקעות נדל״ן',
};
---

<BaseLayout
  title="ליווי רכישת קרקע"
  description="ליווי מקיף לרכישת קרקע להשקעה - איתור, בדיקות, משא ומתן וסגירה. על ידי שמאית מקרקעין מוסמכת. 15,000 ש״ח מחיר קבוע."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="ליווי רכישת קרקע"
    subtitle="מהרגע שמחליטים להשקיע בקרקע ועד לחתימה על החוזה - אנחנו איתכם בכל שלב. איתור, בדיקות, משא ומתן וסגירה."
    
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ חינם"
  />

  <TrustBar variant="light" />

  <!-- What's Included -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה כולל השירות?
        </h2>

        <div class="space-y-6">
          {[
            {
              title: 'הגדרת אסטרטגיה',
              desc: 'פגישת היכרות להבנת היעדים שלכם - האם מחפשים קרקע לבנייה עצמית, להשקעה לטווח ארוך, או קרקע עם פוטנציאל שינוי ייעוד.',
            },
            {
              title: 'איתור קרקעות מתאימות',
              desc: 'חיפוש פרואקטיבי של קרקעות שעומדות בקריטריונים - לא רק מה שמפורסם, אלא גם הזדמנויות שמגיעות דרך קשרים בשוק.',
            },
            {
              title: 'בדיקות מקיפות',
              desc: 'לכל קרקע רלוונטית נבצע בדיקה תכנונית (תב״ע, זכויות), משפטית (בעלות, שעבודים) וכלכלית (שווי, פוטנציאל).',
            },
            {
              title: 'ניהול משא ומתן',
              desc: 'ניהול המשא ומתן מול המוכר או נציגיו - מתוך ידע מעמיק על שווי הקרקע והמצב התכנוני.',
            },
            {
              title: 'ליווי עד לסגירה',
              desc: 'עבודה מול עורך הדין, בדיקת החוזה, וליווי מלא עד לחתימה ורישום הזכויות.',
            },
          ].map((item) => (
            <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
              <div class="flex-shrink-0 w-8 h-8 bg-brand-100 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-1">{item.title}</h3>
                <p class="text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps
    title="תהליך העבודה"
    subtitle="ארבעה שלבים לרכישת קרקע מוצלחת"
    steps={serviceSteps}
  />

  <!-- Why Important -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          למה לקחת ליווי לרכישת קרקע?
        </h2>

        <div class="space-y-6">
          {[
            {
              title: 'מורכבות גבוהה',
              desc: 'עסקאות קרקע מורכבות הרבה יותר מדירות - תב״ע, הסכמי שיתוף, זכויות בנייה, היטלי השבחה. בלי ליווי מקצועי קל לטעות.',
            },
            {
              title: 'סיכון גבוה',
              desc: 'קרקע שנראית זולה יכולה להתברר כהשקעה גרועה אם לא בודקים לעומק את המצב התכנוני והמשפטי.',
            },
            {
              title: 'הזדמנויות נסתרות',
              desc: 'קרקעות איכותיות לא תמיד מפורסמות. עם הקשרים והניסיון שלנו, נמצא הזדמנויות שלא תמצאו לבד.',
            },
            {
              title: 'חיסכון בזמן',
              desc: 'במקום לבזבז חודשים על חיפוש ובדיקות, אנחנו עושים את העבודה ומביאים לכם רק אופציות שכדאי לשקול.',
            },
          ].map((item) => (
            <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
              <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-1">{item.title}</h3>
                <p class="text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
          מחיר השירות
        </h2>
        <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
          <div class="text-5xl font-bold text-brand-600 mb-2">₪15,000</div>
          <div class="text-muted mb-6">מחיר קבוע | כולל את כל השירותים</div>
          <ul class="text-start space-y-3 mb-8">
            {['הגדרת אסטרטגיה ויעדים', 'איתור קרקעות מתאימות', 'בדיקות מקיפות (ללא הגבלה)', 'ניהול משא ומתן', 'ליווי עד לסגירה'].map((item) => (
              <li class="flex items-center gap-2 text-dark">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="#contact"
            class="block w-full py-4 bg-accent hover:bg-accent-dark text-white rounded-md font-semibold transition-all duration-300"
          >
            התחילו עכשיו
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          דוגמה לעסקת קרקע שליווינו
        </h2>

        <div class="bg-white rounded-2xl p-6 md:p-8 border border-border">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-semibold text-dark text-lg mb-4">מגרש בנשר - ליד הטכניון</h3>
              <p class="text-muted mb-4">
                לקוח פנה אלינו עם עניין במגרש שפורסם למכירה ב-1.8 מיליון ש״ח.
                הבדיקה שלנו גילתה: זכויות בנייה של 180% במקום 120% שפורסם, אך גם הערת אזהרה שלא צוינה.
              </p>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-dark">זיהינו זכויות בנייה גבוהות יותר ממה שפורסם</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-dark">טיפלנו בהסרת הערת האזהרה לפני הרכישה</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-dark">הורדנו את המחיר ב-120,000 ש״ח במשא ומתן</span>
                </li>
              </ul>
            </div>
            <div class="flex flex-col justify-center">
              <div class="grid grid-cols-2 gap-4 text-center">
                <div class="bg-brand-50 rounded-xl p-4">
                  <div class="text-2xl font-bold text-brand-600 mb-1">120K</div>
                  <div class="text-sm text-muted">חיסכון במחיר</div>
                </div>
                <div class="bg-success-50 rounded-xl p-4">
                  <div class="text-2xl font-bold text-success-600 mb-1">60%</div>
                  <div class="text-sm text-muted">יותר זכויות בנייה</div>
                </div>
              </div>
              <p class="text-center text-muted text-sm mt-4">
                * הלקוח בנה בית דו-משפחתי ומכר יחידה אחת ברווח של 450,000 ש״ח
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- E-E-A-T Section - About Maayan -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div class="lg:col-span-1 flex justify-center">
            <div class="relative">
              <img
                src="/images/team/maayan-portrait.webp"
                alt="מעיין ליבנה - שמאית מקרקעין מוסמכת"
                class="w-64 h-auto rounded-2xl shadow-lg"
                loading="lazy"
              />
              <div class="absolute -bottom-4 -right-4 bg-brand-600 text-white px-4 py-2 rounded-lg text-sm font-medium shadow-lg">
                15 שנות ניסיון
              </div>
            </div>
          </div>

          <div class="lg:col-span-2">
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-6">
              הכירו את מעיין ליבנה
            </h2>
            <p class="text-muted mb-4">
              שמאית מקרקעין מוסמכת עם 15 שנות ניסיון בשוק הנדל״ן הישראלי. מתמחה בהערכת שווי קרקעות, ניתוח זכויות בנייה ובדיקת כדאיות עסקאות קרקע.
            </p>

            <ul class="space-y-3 mb-6">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">רישיון שמאות מקרקעין מטעם מועצת השמאים</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">מאות שומות קרקע לבנקים, יזמים ולקוחות פרטיים</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">התמחות בקרקעות לבנייה, קרקע חקלאית ומתחמי התחדשות</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-dark">גישה למידע תכנוני ורישומי שלא זמין לציבור</span>
              </li>
            </ul>

            <p class="text-muted italic border-r-4 border-brand-200 pr-4">
              "עסקאות קרקע מורכבות יותר מדירות. יש יותר מקום לטעויות, אבל גם יותר הזדמנויות למי שיודע לזהות אותן. אני כאן כדי לוודא שאתם בצד הנכון של המשוואה."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="מחפשים קרקע להשקעה?"
    subtitle="נעזור לכם למצוא את ההזדמנות הנכונה - עם ליווי מקצועי בכל שלב"
  />

  <TestimonialSection />

  <FAQ
    title="שאלות נפוצות על ליווי רכישת קרקע"
    items={faqItems}
  />

  <!-- Related Services -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-xl md:text-2xl font-bold text-dark mb-6 text-center">
          שירותים נוספים שעשויים לעניין אתכם
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="/land-deal-assessment/" class="block p-6 bg-white rounded-xl border border-border hover:border-brand-300 transition-colors">
            <h3 class="font-semibold text-dark mb-2">בדיקת עסקת קרקע</h3>
            <p class="text-muted text-sm mb-2">יש לכם קרקע ספציפית שאתם שוקלים? בדיקה חד-פעמית ב-2,500 ש״ח.</p>
            <span class="text-brand-600 text-sm font-medium">לפרטים ←</span>
          </a>

