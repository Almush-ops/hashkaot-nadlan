---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const faqItems = [
  {
    question: 'מה ההבדל בין ליווי רכישת קרקע לבדיקת עסקת קרקע?',
    answer: '<a href="/land-deal-assessment/" class="text-brand-600 hover:underline">בדיקת עסקת קרקע</a> היא בדיקה חד-פעמית לקרקע ספציפית שאתם כבר מצאתם (2,500 ש״ח). ליווי רכישת קרקע הוא שירות מקיף שכולל איתור קרקעות מתאימות, בדיקות מרובות, ניהול משא ומתן וליווי עד לחתימה.',
  },
  {
    question: 'כמה עולה ליווי רכישת קרקע?',
    answer: 'עלות הליווי המלא היא 15,000 ש״ח (כולל מע״מ). התשלום מתחלק ל-5,000 ש״ח מקדמה בתחילת הליווי ו-10,000 ש״ח בחתימה על העסקה. המחיר כולל איתור, בדיקות מרובות (ללא הגבלה), ניהול משא ומתן וליווי עד לסגירה.',
  },
  {
    question: 'איזה סוגי קרקעות אתם מלווים?',
    answer: 'אנחנו מתמחים בקרקעות צהובות (בתהליכי הפשרה מתקדמים), קרקע למגורים עם זכויות בנייה, קרקע חקלאית עם פוטנציאל שינוי ייעוד, מגרשים בפרצלציה, וקרקע בייעוד מסחרי. לא מלווים ברכישת קרקע חקלאית "ירוקה" ללא תכנון.',
  },
  {
    question: 'מה זה "מחיר ראוי" לקרקע?',
    answer: 'מחיר ראוי הוא מחיר שמשקף את המציאות הקיימת - לא את התקווה. הוא מבוסס על: הייעוד הקיים של הקרקע, שלב התכנון שבו היא נמצאת, מגבלות רגולטוריות, לוחות זמנים למימוש, ורמת אי-הוודאות. זה מחיר שמאפשר להיכנס לעסקה מתוך היגיון כלכלי.',
  },
  {
    question: 'כמה זמן לוקח למצוא קרקע מתאימה?',
    answer: 'בממוצע 3-6 חודשים, תלוי בדרישות ובתקציב. קרקעות איכותיות עם פוטנציאל אמיתי דורשות סבלנות וחיפוש מעמיק. אנחנו לא ממהרים למכור - עדיף לחכות לעסקה נכונה מאשר להיכנס לעסקה בינונית.',
  },
  {
    question: 'מה הבדיקות שאתם מבצעים לכל קרקע?',
    answer: 'כל קרקע עוברת 3 בדיקות: (1) בדיקה תכנונית - תב״ע, זכויות בנייה, שלב התכנון, צפי לאישורים. (2) בדיקה משפטית - בעלות, שעבודים, הערות אזהרה, הסכמי שיתוף. (3) בדיקה כלכלית - שווי נוכחי, פוטנציאל, היטלי השבחה צפויים, עלויות פיתוח.',
  },
  {
    question: 'למי מתאים להשקיע בקרקע?',
    answer: 'השקעה בקרקע מתאימה למי שמבין שזו השקעה תכנונית (לא נדל״ן מניב), מחפש השבחת הון ולא הכנסה שוטפת, מוכן לוותר על ודאות לטובת פוטנציאל, ומעדיף מסמכים ונתונים על פני הבטחות. זה לא מתאים למי שמחפש קיצור דרך או תשואה מיידית.',
  },
  {
    question: 'האם המקדמה מוחזרת אם לא מצאתם לי קרקע?',
    answer: 'המקדמה של 5,000 ש״ח לא מוחזרת במקרה של נסיגה מצד הלקוח, כי היא משקפת עבודת ייעוץ, מחקר ובדיקות שכבר בוצעו. עם זאת, אנחנו ממשיכים לחפש עד שמוצאים את הקרקע המתאימה - אין מגבלת זמן.',
  },
];

const serviceSteps = [
  { number: 1, title: 'הגדרת צרכים', description: 'פגישת היכרות להבנת היעדים, התקציב וסוג הקרקע המבוקש.' },
  { number: 2, title: 'איתור קרקעות', description: 'חיפוש מעמיק וסינון ראשוני של קרקעות פוטנציאליות.' },
  { number: 3, title: 'בדיקות מקיפות', description: 'בדיקה תכנונית, משפטית וכלכלית לכל קרקע רלוונטית.' },
  { number: 4, title: 'משא ומתן וסגירה', description: 'ניהול המשא ומתן וליווי עד לחתימת החוזה.' },
];

// Case studies data
const caseStudies = [
  {
    title: 'קרקע צהובה בבאר יעקב',
    description: 'ליווינו משקיע לרכישת קרקע בתהליכי הפשרה. הבדיקה השמאית זיהתה שהמחיר המבוקש גבוה ב-15% מהשווי הריאלי',
    result: '85,000 ש״ח',
    resultLabel: 'חיסכון במשא ומתן',
  },
  {
    title: 'קרקע בכפר יונה - מגורים ג׳',
    description: 'זיהינו בעיה תכנונית שהמוכר לא חשף. חסכנו ללקוח השקעה בקרקע בעייתית',
    result: '200,000+ ש״ח',
    resultLabel: 'נמנע מהפסד',
  },
  {
    title: 'קבוצת רוכשים - גבעת שמואל',
    description: 'ארגנו קבוצת רוכשים לקרקע בשלבי תכנון מתקדמים. כוח הקנייה הוריד את המחיר',
    result: '12%',
    resultLabel: 'הנחה מתחת למחיר השוק',
  },
  {
    title: 'קרקע בראשון לציון - אנ״מ צפוני',
    description: 'בדקנו קרקע שהוצעה "במחיר הזדמנות". גילינו היטלי השבחה צפויים שלא נלקחו בחשבון',
    result: '150,000 ש״ח',
    resultLabel: 'חשיפת עלויות נסתרות',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'ליווי רכישת קרקע',
  description: 'ליווי מקיף לרכישת קרקע להשקעה על ידי שמאית מקרקעין מוסמכת. איתור קרקעות, בדיקות תכנוניות ומשפטיות, ניהול משא ומתן וסגירה. מחיר קבוע 15,000 ש״ח.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
    telephone: '+972-55-255-5144',
  },
  areaServed: 'ישראל',
  serviceType: 'ליווי רכישת קרקע',
  offers: {
    '@type': 'Offer',
    price: '15000',
    priceCurrency: 'ILS',
    description: 'ליווי מקיף מקצה לקצה לרכישת קרקע',
  },
};
---

<BaseLayout
  title="ליווי רכישת קרקע - שמאית מקרקעין מוסמכת"
  description="ליווי מקיף לרכישת קרקע להשקעה על ידי שמאית מקרקעין עם 15 שנות ניסיון. איתור קרקעות, בדיקות תכנוניות ומשפטיות. 15,000 ש״ח מחיר קבוע."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="ליווי רכישת קרקע"
    subtitle="קרקע זו השקעה תכנונית - לא הבטחה. אנחנו מלווים אתכם מהרגע שמחליטים להשקיע ועד לחתימה על החוזה, עם בדיקות מקיפות ושקיפות מלאה."
    backgroundImage="/images/hero/hero-02.webp"
    showCTA={true}
    ctaText="השאירו פרטים לייעוץ חינם"
  />

  <TrustBar variant="light" />

  <!-- Stats Section -->
  <section class="py-12 bg-brand-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">120+</div>
            <div class="text-sm text-muted">בדיקות קרקע שבוצעו</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">35+</div>
            <div class="text-sm text-muted">עסקאות קרקע שנסגרו</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">40%</div>
            <div class="text-sm text-muted">מהקרקעות נפסלו בבדיקה</div>
          </div>
          <div>
            <div class="text-3xl md:text-4xl font-bold text-brand-600 mb-1">15</div>
            <div class="text-sm text-muted">שנות ניסיון בשמאות</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-6">
          קרקע זו השקעה - לא הבטחה
        </h2>
        <p class="text-muted text-lg mb-8">
          בשוק הקרקעות נוצר בלבול מכוון בין <strong>מחיר</strong> לבין <strong>שווי</strong>. רוב ההצעות מבוססות על סיפור עתידי: מה יהיה, מה יאושר, כמה זה "אמור" להיות שווה. אנחנו עובדים הפוך.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-right">
          <div class="p-6 bg-surface rounded-xl border border-border">
            <h3 class="font-semibold text-dark mb-3">השאלות שאנחנו שואלים:</h3>
            <ul class="space-y-2 text-muted">
              <li class="flex items-start gap-2">
                <span class="text-brand-600 mt-1">←</span>
                <span>מה הסטטוס התכנוני היום?</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-600 mt-1">←</span>
                <span>מה ניתן להוכיח במסמכים?</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-600 mt-1">←</span>
                <span>מה שווי הקרקע במצבה הנוכחי?</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-600 mt-1">←</span>
                <span>מה רמת הסיכון והזמן למימוש?</span>
              </li>
            </ul>
          </div>
          <div class="p-6 bg-brand-50 rounded-xl border border-brand-100">
            <h3 class="font-semibold text-dark mb-3">העיקרון שלנו:</h3>
            <p class="text-muted mb-4">
              רק אחרי שיש תשובות - מדברים על עסקה. אם הנתונים לא מסתדרים - העסקה לא יוצאת לדרך.
            </p>
            <p class="text-dark font-medium">
              אנחנו לא מבטיחים עליית ערך. אנחנו בונים עסקה שאפשר להצדיק.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
            איך הבדיקות שלנו חוסכות כסף
          </h2>
          <p class="text-muted max-w-2xl mx-auto">
            40% מהקרקעות שבדקנו נפסלו - או שהמחיר לא היה הוגן, או שהיו בעיות תכנוניות/משפטיות. הנה דוגמאות אמיתיות.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {caseStudies.map((study) => (
            <div class="p-6 bg-white rounded-xl border border-border hover:border-brand-200 transition-colors">
              <h3 class="font-semibold text-dark mb-2">{study.title}</h3>
              <p class="text-muted text-sm mb-4">{study.description}</p>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-success-600">{study.result}</span>
                <span class="text-sm text-muted">{study.resultLabel}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What's Different -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה שונה בליווי שלנו?
        </h2>

        <div class="space-y-6">
          <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">אנחנו לא חברת שיווק קרקעות</h3>
              <p class="text-muted">לא מוכרים חלומות, לא מפעילים לחץ, לא בונים עסקאות סביב "הזדמנות אחרונה". אנחנו גוף מקצועי שמארגן רכישה רק אחרי בדיקה כלכלית, תכנונית ומשפטית מלאה.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">שמאית מקרקעין מוסמכת עושה את הבדיקות</h3>
              <p class="text-muted">מעיין היא שמאית מקרקעין מוסמכת עם 15 שנות ניסיון. היא לא רק בודקת - היא יודעת בדיוק מה השווי האמיתי של הקרקע, לא מה המוכר רוצה שתאמינו.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">כוח קנייה של קבוצה - מחיר של יחיד</h3>
              <p class="text-muted">כשמתאים, אנחנו מארגנים קבוצות רוכשים. קבוצה היא כלי להורדת מחיר - לא מוצר. הערך נוצר רק כשיש פער אמיתי בין מחיר השוק למחיר הרכישה.</p>
            </div>
          </div>

          <div class="flex gap-4 p-6 bg-surface rounded-xl border border-border">
            <div class="flex-shrink-0 w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-dark mb-2">שקיפות מלאה - גם על הסיכונים</h3>
              <p class="text-muted">אנחנו מראים את כל התמונה - לא רק את הפוטנציאל. מה המגבלות, מה לוחות הזמנים הריאליסטיים, ומה יכול להשתבש. מסמכים ונתונים - לא הבטחות.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Land Types -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          סוגי קרקעות שאנחנו מלווים
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-6 bg-white rounded-xl border border-border text-center">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark mb-2">קרקעות צהובות</h3>
            <p class="text-muted text-sm">קרקעות בתהליכי הפשרה מתקדמים - כבר בייעוד מגורים או בתכנון סופי.</p>
          </div>

          <div class="p-6 bg-white rounded-xl border border-border text-center">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
