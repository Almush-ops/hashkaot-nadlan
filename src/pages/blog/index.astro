---
import BaseLayout from '../../layouts/BaseLayout.astro';

// For static blog: use Astro Content Collections
// For WordPress CMS: uncomment the import below and use fetchPosts()
// import { fetchPosts } from '../../lib/wordpress';
// const posts = await fetchPosts();

// Placeholder posts - replace with real data source
const posts: Array<{slug: string; title: string; excerpt: string; date: string; image: string | null}> = [
  // TODO: Add real blog posts here
];
---

<BaseLayout
  title="מאמרים"
  description="מאמרים ומדריכים על השקעות נדל״ן, קרקעות, תמ״א 38 והתחדשות עירונית. טיפים להשקעה חכמה מצוות מעין ואור ליבנה."
  noindex={true}
>
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-12">מאמרים</h1>
        <p class="text-lg text-muted mb-12 -mt-8">בקרוב - מאמרים ומדריכים על השקעות נדל״ן בישראל</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="group rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-md transition-shadow border border-gray-100">
            {post.image && (
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
            )}
            <div class="p-6">
              <time class="text-sm text-gray-500">{post.date}</time>
              <h2 class="mt-2 text-xl font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="mt-3 text-gray-600 line-clamp-3">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
