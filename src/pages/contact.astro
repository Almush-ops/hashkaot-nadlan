---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQ from '../components/FAQ.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'צור קשר' },
];

const phone = '055-2555144';
const email = 'maayan@maayanlivne.co.il';
const address = 'כביש ההר הירוק, יגור';

const faqItems = [
  {
    question: 'מה שעות הפעילות שלכם?',
    answer: 'אנחנו זמינים בימים א\'-ה\' בין 9:00 ל-18:00. ניתן להשאיר הודעה בכל שעה ונחזור אליכם בהקדם.',
  },
  {
    question: 'כמה זמן לוקח לקבל תשובה?',
    answer: 'אנחנו משתדלים לחזור לכל פנייה תוך יום עסקים אחד. פניות דחופות - התקשרו ישירות.',
  },
  {
    question: 'האם אפשר להיפגש פיזית?',
    answer: 'בהחלט! המשרד שלנו נמצא בקיבוץ יגור. אנחנו גם יכולים להגיע אליכם או להיפגש באזור הנכס.',
  },
];

// LocalBusiness schema
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'השקעות נדל״ן - מעין ואור ליבנה',
  image: 'https://hashkaot-nadlan.co.il/images/logo.png',
  telephone: '+972-55-2555144',
  email: 'maayan@maayanlivne.co.il',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'כביש ההר הירוק',
    addressLocality: 'יגור',
    postalCode: '3006500',
    addressCountry: 'IL',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
    opens: '09:00',
    closes: '18:00',
  },
};
---

<BaseLayout
  title="צור קשר"
  description="צרו קשר עם מעין ואור ליבנה לייעוץ השקעות נדל״ן. טלפון: 055-2555144, כתובת: קיבוץ יגור. תגובה תוך יום עסקים."
>
  <SchemaOrg schema={localBusinessSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-12 md:py-16">
    <div class="container mx-auto px-4">
      <Breadcrumbs items={breadcrumbs} />

      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark leading-tight mb-6">
          צור קשר
        </h1>
        <p class="text-lg md:text-xl text-muted">
          יש לכם שאלה? רוצים לשמוע עוד? השאירו פרטים ונחזור אליכם בהקדם.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info + Form -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
          <!-- Contact Info -->
          <div class="lg:col-span-2 space-y-8">
            <div>
              <h2 class="font-heading text-xl font-bold text-dark mb-6">פרטי התקשרות</h2>

              <div class="space-y-4">
                <!-- Phone -->
                <a href={`tel:${phone}`} class="flex items-start gap-4 p-4 bg-surface rounded-xl hover:bg-brand-50 transition-colors group">
                  <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 group-hover:bg-brand-200 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">טלפון</div>
                    <div class="text-brand-600">{phone}</div>
                  </div>
                </a>

                <!-- Email -->
                <a href={`mailto:${email}`} class="flex items-start gap-4 p-4 bg-surface rounded-xl hover:bg-brand-50 transition-colors group">
                  <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 group-hover:bg-brand-200 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">אימייל</div>
                    <div class="text-brand-600">{email}</div>
                  </div>
                </a>

                <!-- Address -->
                <div class="flex items-start gap-4 p-4 bg-surface rounded-xl">
                  <div class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <div class="font-semibold text-dark">כתובת</div>
                    <div class="text-muted">{address}</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Hours -->
            <div>
              <h3 class="font-semibold text-dark mb-3">שעות פעילות</h3>
              <ul class="space-y-2 text-muted">
                <li class="flex justify-between">
                  <span>ימים א' - ה'</span>
                  <span>09:00 - 18:00</span>
                </li>
                <li class="flex justify-between">
                  <span>יום ו' ושבת</span>
                  <span>סגור</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Form -->
          <div class="lg:col-span-3">
            <div class="bg-surface rounded-xl p-6 md:p-8">
              <h2 class="font-heading text-xl font-bold text-dark mb-6">השאירו פרטים</h2>
              <ContactForm variant="standalone" title="" subtitle="" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section class="py-8 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="bg-brand-100 rounded-xl h-64 flex items-center justify-center">
          <div class="text-center text-muted">
            <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p>מפה תתווסף כאן</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ
    title="שאלות נפוצות"
    items={faqItems}
  />
</BaseLayout>
