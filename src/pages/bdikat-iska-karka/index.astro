---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TrustBar from '../../components/TrustBar.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const breadcrumbs = [
  { label: 'דף הבית', href: '/' },
  { label: 'בדיקת עסקת קרקע' },
];

const faqItems = [
  {
    question: 'מה כולל שירות בדיקת עסקת קרקע?',
    answer: 'הבדיקה כוללת: ניתוח תכנוני (תב״ע, זכויות בנייה), בדיקה משפטית (בעלות, שעבודים, הערות אזהרה), וניתוח כלכלי (שווי נוכחי, פוטנציאל השבחה).',
  },
  {
    question: 'כמה עולה בדיקת עסקת קרקע?',
    answer: 'עלות הבדיקה היא 2,500 ש״ח + מע״מ. זהו מחיר קבוע שכולל את כל הבדיקות - תכנוני, משפטי וכלכלי.',
  },
  {
    question: 'כמה זמן לוקחת הבדיקה?',
    answer: 'בדיקה סטנדרטית לוקחת 3-5 ימי עבודה. במקרים מורכבים יותר (קרקע חקלאית, שותפים רבים וכו\') הזמן עשוי להתארך.',
  },
  {
    question: 'האם הבדיקה מתאימה לקרקע חקלאית?',
    answer: 'כן, אנחנו מתמחים גם בבדיקת קרקעות חקלאיות. הבדיקה תכלול ניתוח סיכויי שינוי ייעוד, מגבלות תכנוניות וציפיות ריאליות.',
  },
  {
    question: 'מה קורה אם הבדיקה מגלה בעיות?',
    answer: 'נציג לכם דוח מפורט עם כל הממצאים, כולל המלצות פעולה. במקרים רבים, גילוי בעיות מאפשר לנהל משא ומתן על המחיר או לוותר על העסקה בזמן.',
  },
];

// Service schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'בדיקת עסקת קרקע',
  description: 'בדיקת עסקת קרקע מקיפה על ידי שמאית מקרקעין מוסמכת - ניתוח תכנוני, משפטי וכלכלי',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
  },
  areaServed: 'ישראל',
  serviceType: 'שמאות מקרקעין',
  offers: {
    '@type': 'Offer',
    price: '2500',
    priceCurrency: 'ILS',
  },
};
---

<BaseLayout
  title="בדיקת עסקת קרקע"
  description="בדיקת עסקת קרקע מקיפה על ידי שמאית מקרקעין מוסמכת. ניתוח תכנוני, משפטי וכלכלי ב-2,500 ש״ח + מע״מ. צרו קשר לייעוץ."
>
  <SchemaOrg schema={serviceSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-12 md:py-20">
    <div class="container mx-auto px-4">
      <Breadcrumbs items={breadcrumbs} />

      <div class="max-w-3xl">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-dark leading-tight mb-6">
          בדיקת עסקת קרקע
        </h1>
        <p class="text-lg md:text-xl text-muted mb-8">
          בדיקה מקיפה על ידי שמאית מקרקעין מוסמכת - כדי שתדעו בדיוק מה אתם קונים לפני שאתם חותמים.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="px-8 py-4 bg-accent hover:bg-accent-dark text-white rounded-md font-semibold text-lg transition-all duration-300 hover:shadow-xl text-center">
            הזמינו בדיקת קרקע
          </a>
          <a href="tel:055-2555144" class="px-8 py-4 bg-white hover:bg-brand-50 text-brand-700 border-2 border-brand-200 rounded-md font-semibold text-lg transition-all duration-300 text-center">
            055-2555144
          </a>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- What's Included -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-12 text-center">
          מה כולל שירות הבדיקה?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              title: 'בדיקה תכנונית',
              items: ['תכנית בניין עיר (תב״ע)', 'זכויות בנייה', 'ייעוד קרקע', 'הגבלות בנייה', 'תכניות עתידיות'],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>`,
            },
            {
              title: 'בדיקה משפטית',
              items: ['אימות בעלות', 'שעבודים ועיקולים', 'הערות אזהרה', 'הסכמי שיתוף', 'זכויות צד ג\''],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>`,
            },
            {
              title: 'בדיקה כלכלית',
              items: ['הערכת שווי נוכחי', 'פוטנציאל השבחה', 'עלויות פיתוח', 'השוואה לעסקאות דומות', 'תחזית תשואה'],
              icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
            },
          ].map((category) => (
            <div class="bg-surface rounded-xl p-6 border border-border">
              <div class="w-14 h-14 bg-brand-100 rounded-lg flex items-center justify-center text-brand-600 mb-4" set:html={category.icon} />
              <h3 class="font-heading font-bold text-dark text-lg mb-4">{category.title}</h3>
              <ul class="space-y-2">
                {category.items.map((item) => (
                  <li class="flex items-center gap-2 text-muted text-sm">
                    <svg class="w-4 h-4 text-brand-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Important -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          למה חשוב לבדוק קרקע לפני רכישה?
        </h2>

        <div class="space-y-6">
          {[
            {
              title: 'הימנעות מהפסדים',
              desc: 'בדיקה מקצועית יכולה לחשוף בעיות שיעלו לכם מאות אלפי שקלים - לפני שזה קורה.',
            },
            {
              title: 'משא ומתן מושכל',
              desc: 'ידע הוא כוח. כשאתם יודעים בדיוק מה יש בקרקע, אתם יכולים לנהל משא ומתן חכם יותר.',
            },
            {
              title: 'שקט נפשי',
              desc: 'אחרי הבדיקה תדעו בדיוק מה אתם קונים - בלי הפתעות לא נעימות בהמשך.',
            },
            {
              title: 'תכנון נכון',
              desc: 'הבנת זכויות הבנייה והפוטנציאל מאפשרת תכנון פיננסי מדויק של ההשקעה.',
            },
          ].map((item) => (
            <div class="flex gap-4 p-6 bg-white rounded-xl border border-border">
              <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark mb-1">{item.title}</h3>
                <p class="text-muted">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
          מחיר השירות
        </h2>
        <div class="bg-brand-50 rounded-2xl p-8 border border-brand-100">
          <div class="text-5xl font-bold text-brand-600 mb-2">₪2,500</div>
          <div class="text-muted mb-6">+ מע״מ | כולל את כל הבדיקות</div>
          <ul class="text-start space-y-3 mb-8">
            {['בדיקה תכנונית מלאה', 'בדיקה משפטית מקיפה', 'ניתוח כלכלי', 'דוח מפורט בכתב', 'שיחת סיכום'].map((item) => (
              <li class="flex items-center gap-2 text-dark">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="#contact"
            class="block w-full py-4 bg-accent hover:bg-accent-dark text-white rounded-md font-semibold transition-all duration-300"
          >
            הזמינו בדיקה עכשיו
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="לא בטוחים לגבי הקרקע?"
    subtitle="בדיקה מקצועית תיתן לכם את התשובות שאתם צריכים"
    ctaText="הזמינו בדיקה"
  />

  <FAQ
    title="שאלות נפוצות על בדיקת קרקע"
    items={faqItems}
  />

  <ContactForm
    title="הזמינו בדיקת קרקע"
    subtitle="מלאו את הפרטים ונחזור אליכם בהקדם לתיאום הבדיקה"
  />
</BaseLayout>
