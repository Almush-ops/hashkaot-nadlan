---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const faqItems = [
  {
    question: 'מה זו קבוצת רכישה?',
    answer: 'קבוצת רכישה היא התארגנות של מספר רוכשים שמתאגדים יחד לרכישת קרקע ובניית פרויקט מגורים, תוך דילוג על היזם. במקום לקנות דירה מוכנה מקבלן, הקבוצה רוכשת קרקע, שוכרת קבלן מבצע ובונה בעצמה — ובכך חוסכת את רווח היזם שמגיע ל-15%-25% מהפרויקט.',
  },
  {
    question: 'כמה אפשר לחסוך בקבוצת רכישה?',
    answer: 'החיסכון הממוצע בקבוצת רכישה מוצלחת נע בין 15% ל-25% ממחיר דירה זהה מקבלן. על דירה שעולה 2 מיליון ש״ח בשוק החופשי, החיסכון יכול להגיע ל-300,000-500,000 ש״ח. עם זאת, חשוב להבין שיש גם סיכונים ועלויות נסתרות שיכולים לאכול חלק מהחיסכון.',
  },
  {
    question: 'מה הסיכונים בקבוצת רכישה?',
    answer: 'הסיכונים העיקריים כוללים: עיכובים בבנייה (ממוצע של 2-3 שנים מעבר ללו״ז), חריגות בעלויות (תוספות של 10%-20% מהתקציב), קושי בקבלת משכנתא (הבנקים זהירים עם קבוצות), ובעיות ניהול ושקיפות. קבוצות רבות נכשלו והשאירו רוכשים ללא דירה וללא כסף.',
  },
  {
    question: 'איך יודעים אם קבוצת רכישה אמינה?',
    answer: 'צריך לבדוק את <a href="/land-deal-assessment/" class="text-brand-600 hover:underline">המארגן ואת העסקה</a>: ניסיון קודם בניהול קבוצות, בעלות על הקרקע ומצבה התכנוני, הסכם התארגנות מפורט, ערבויות וביטחונות, דו״חות כספיים, וחוות דעת של משתתפים קודמים. אנחנו מבצעים בדיקה מקיפה של כל הפרמטרים האלה.',
  },
  {
    question: 'מה כולל שירות הבדיקה שלכם?',
    answer: 'השירות כולל: בדיקת הקרקע ומצבה התכנוני, בדיקת המארגן והיסטוריה שלו, ניתוח הסכם ההתארגנות והתשלומים, השוואת מחירים מול שוק חופשי, זיהוי סיכונים ונקודות חולשה, והמלצה מקצועית האם להצטרף או לא.',
  },
  {
    question: 'האם אתם ממליצים על קבוצות רכישה?',
    answer: 'זה תלוי בקבוצה הספציפית ובמצב שלכם. קבוצת רכישה מתאימה למי שיש לו הון עצמי גבוה, יכולת לחכות 3-5 שנים, וסיבולת לאי-ודאות. לרוב המשקיעים, דירה מוכנה מקבלן או יד שנייה היא אופציה בטוחה יותר. אנחנו עוזרים לכם להבין מה מתאים לכם.',
  },
  {
    question: 'כמה עולה הבדיקה?',
    answer: 'בדיקת קבוצת רכישה עולה 3,500-5,000 ש״ח (תלוי במורכבות העסקה). זה כולל בדיקת קרקע, ניתוח הסכמים, והמלצה מקצועית. על עסקה של מיליון ש״ח ומעלה — זו השקעה קטנה שיכולה לחסוך לכם מאות אלפים.',
  },
  {
    question: 'מה ההבדל בינכם לבין יועץ של הקבוצה?',
    answer: 'אנחנו עובדים עבורכם ולא עבור מארגן הקבוצה. היועצים של הקבוצה ממומנים על ידי המארגן ויש להם אינטרס שהעסקה תיסגר. אנחנו אובייקטיביים לחלוטין — אם הקבוצה לא טובה, נגיד לכם בברור.',
  },
];

const serviceSteps = [
  { number: 1, title: 'קבלת חומרים', description: 'קבלו הצעה להצטרף לקבוצה? שלחו לנו את כל החומרים — הסכם, מצגת, פרטי הקרקע.' },
  { number: 2, title: 'בדיקה מקיפה', description: 'נבצע בדיקה של הקרקע, המארגן, ההסכם והמספרים. נזהה סיכונים ונקודות חולשה.' },
  { number: 3, title: 'דוח והמלצה', description: 'תקבלו דו״ח מפורט עם כל הממצאים והמלצה ברורה: להצטרף, לנהל מו״מ, או לוותר.' },
  { number: 4, title: 'ליווי (אופציונלי)', description: 'אם תחליטו להצטרף — נלווה אתכם במו״מ, בחתימה ובמעקב אחרי התקדמות הפרויקט.' },
];

// Service schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'בדיקת קבוצת רכישה - ייעוץ וליווי להצטרפות לקבוצות רכישה',
  description: 'שירות בדיקה וייעוץ לקבוצות רכישה. בדיקת הקרקע, המארגן וההסכם - המלצה אובייקטיבית האם להצטרף. שמאית מקרקעין מוסמכת.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
    telephone: '+972-55-255-5144',
  },
  areaServed: ['ישראל'],
  serviceType: 'בדיקת קבוצת רכישה',
  offers: {
    '@type': 'Offer',
    price: '3500',
    priceCurrency: 'ILS',
    description: 'בדיקה מקיפה של קבוצת רכישה',
  },
};
---

<BaseLayout
  title="קבוצת רכישה - בדיקה וייעוץ לפני הצטרפות | שמאית מקרקעין"
  description="חושבים להצטרף לקבוצת רכישה? בדיקה מקצועית של הקרקע, המארגן וההסכם. המלצה אובייקטיבית האם כדאי להצטרף. שמאית מקרקעין מוסמכת עם 15 שנות ניסיון."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="בדיקת קבוצת רכישה"
    subtitle="קיבלתם הצעה להצטרף לקבוצת רכישה? לפני שאתם חותמים על הסכם ומעבירים מאות אלפי שקלים — בואו נבדוק יחד את הקרקע, את המארגן ואת ההסכם. שמאית מקרקעין מוסמכת תיתן לכם המלצה אובייקטיבית."
    backgroundImage="/images/hero/hero-01.webp"
    showCTA={true}
    ctaText="שלחו לנו את פרטי הקבוצה"
  />

  <TrustBar variant="light" />

  <!-- Intro Section -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <p class="text-muted leading-relaxed">
          <strong>קבוצת רכישה</strong> יכולה להיות הזדמנות מצוינת לחסוך 15%-25% ממחיר דירה מקבלן.
          אבל היא גם יכולה להיות מלכודת יקרה מאוד — קבוצות רבות נכשלו, התפרקו, או הסתיימו
          בעיכובים של שנים וחריגות של מאות אלפי שקלים.
        </p>
        <p class="text-muted leading-relaxed">
          הבעיה: <strong>המידע שמקבלים מהמארגן</strong> הוא חלקי ומוטה. המארגן רוצה שתצטרפו —
          יש לו אינטרס ברור. אתם צריכים מישהו שיסתכל על העסקה מהצד שלכם, יבדוק את הקרקע
          באמת, יקרא את ההסכם בעין ביקורתית, ויגיד לכם האם זו עסקה טובה או לא.
        </p>
        <p class="text-muted leading-relaxed">
          אנחנו עושים בדיוק את זה. <strong>שמאית מקרקעין מוסמכת עם 15 שנות ניסיון</strong>
          תבדוק את כל הפרטים ותיתן לכם המלצה אובייקטיבית וברורה.
        </p>
      </div>
    </div>
  </section>

  <!-- Warning Section -->
  <section class="py-12 bg-warning-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="flex gap-4 items-start">
          <div class="flex-shrink-0 w-12 h-12 bg-warning-100 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-warning-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <div>
            <h2 class="font-heading text-xl font-bold text-dark mb-2">
              לפני שחותמים — שאלו את עצמכם
            </h2>
            <ul class="space-y-2 text-muted">
              <li class="flex items-start gap-2">
                <span class="text-warning-600">•</span>
                <span>האם אתם מבינים מה בדיוק אתם קונים? (קרקע? דירה? זכות השתתפות?)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-warning-600">•</span>
                <span>האם בדקתם את הקרקע בעצמכם? (ייעוד, זכויות בנייה, הפקעות)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-warning-600">•</span>
                <span>האם אתם יודעים מה ניסיונו של המארגן? (פרויקטים קודמים, תלונות)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-warning-600">•</span>
                <span>האם קראתם את ההסכם עם עורך דין? (סעיפי יציאה, ערבויות)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-warning-600">•</span>
                <span>האם יש לכם הון לכסות חריגות של 20% מהתקציב?</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Check -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה אנחנו בודקים?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark mb-2">בדיקת הקרקע</h3>
            <p class="text-muted text-sm">ייעוד נוכחי, תב״ע, זכויות בנייה, שטחי ציבור, היטלי השבחה צפויים, בעיות רישום, מצב פיזי.</p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark mb-2">בדיקת המארגן</h3>
            <p class="text-muted text-sm">ניסיון קודם, פרויקטים שהושלמו, תלונות ותביעות, מבנה משפטי, יציבות פיננסית.</p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark mb-2">ניתוח ההסכם</h3>
            <p class="text-muted text-sm">סעיפי יציאה, ערבויות ובטחונות, חלוקת סיכונים, מנגנון חריגות, דמי ניהול ועמלות.</p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark mb-2">השוואת מחירים</h3>
            <p class="text-muted text-sm">השוואה למחירי דירות דומות בשוק, חישוב החיסכון האמיתי, בדיקת הנחות ותחזיות.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pros and Cons -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          יתרונות וחסרונות של קבוצת רכישה
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Pros -->
          <div class="bg-success-50 rounded-xl p-6">
            <h3 class="font-semibold text-success-700 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              יתרונות
            </h3>
            <ul class="space-y-3 text-sm text-success-800">
              <li class="flex items-start gap-2">
                <span class="text-success-600 mt-1">✓</span>
                <span>חיסכון של 15%-25% ממחיר דירה מקבלן</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-success-600 mt-1">✓</span>
                <span>שליטה רבה יותר על תכנון הדירה והפרויקט</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-success-600 mt-1">✓</span>
                <span>שקיפות בעלויות — אתם יודעים לאן הכסף הולך</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-success-600 mt-1">✓</span>
                <span>אפשרות להשפיע על בחירת קבלן, חומרים, גינון</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-success-600 mt-1">✓</span>
                <span>קהילה — מכירים את השכנים לפני הכניסה</span>
              </li>
            </ul>
          </div>

          <!-- Cons -->
          <div class="bg-error-50 rounded-xl p-6">
            <h3 class="font-semibold text-error-700 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              חסרונות וסיכונים
            </h3>
            <ul class="space-y-3 text-sm text-error-800">
              <li class="flex items-start gap-2">
                <span class="text-error-600 mt-1">✗</span>
                <span>עיכובים — רוב הקבוצות מאחרות 2-4 שנים</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-error-600 mt-1">✗</span>
                <span>חריגות תקציב — תוספות של 10%-30% מהעלות</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-error-600 mt-1">✗</span>
                <span>קושי במשכנתא — הבנקים זהירים ודורשים הון גבוה</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-error-600 mt-1">✗</span>
                <span>סיכון התפרקות — אם הקבוצה נכשלת, הכסף בסכנה</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-error-600 mt-1">✗</span>
                <span>מורכבות — דורש זמן, כישורים וסבלנות</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps
    title="איך עובד השירות?"
    subtitle="ארבעה שלבים לבדיקה מקיפה"
    steps={serviceSteps}
  />

  <!-- Pricing -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          עלות השירות
        </h2>

        <div class="bg-brand-50 rounded-2xl p-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl p-6 text-center">
              <div class="text-3xl font-bold text-brand-600 mb-2">3,500-5,000 ש״ח</div>
              <div class="text-muted mb-4">בדיקת קבוצת רכישה</div>
              <ul class="text-sm text-right space-y-2">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>בדיקת קרקע ומצב תכנוני</span>
                </li>
