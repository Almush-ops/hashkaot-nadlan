---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import CTASection from '../../components/CTASection.astro';
import TestimonialSection from '../../components/TestimonialSection.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';


const faqItems = [
  {
    question: 'מה זה קבוצת רכישה?',
    answer: 'קבוצת רכישה היא התאגדות של רוכשים פרטיים לרכישת קרקע ובנייה משותפת, בדרך כלל בליווי מארגן. המטרה היא לחסוך את רווח היזם ולרכוש דירה במחיר נמוך מהשוק. עם זאת, קיימים סיכונים משמעותיים שחשוב לבדוק לפני ההצטרפות.',
  },
  {
    question: 'כמה עולה בדיקת קבוצת רכישה?',
    answer: 'בדיקה בסיסית (קרקע, מארגן, הסכם) עולה 3,500-5,000 ש״ח. בדיקה מקיפה הכוללת ניתוח כלכלי מלא, השוואת מחירים והמלצה מפורטת עולה 8,000-12,000 ש״ח. המחיר משתנה בהתאם למורכבות הפרויקט.',
  },
  {
    question: 'כמה זמן לוקחת הבדיקה?',
    answer: 'בדיקה בסיסית לוקחת 3-5 ימי עבודה. בדיקה מקיפה לוקחת 7-10 ימי עבודה. אם יש לכם דד-ליין לחתימה, עדכנו אותנו ונשתדל להתאים.',
  },
  {
    question: 'מה ההבדל בין קבוצת רכישה לרכישה מיזם?',
    answer: 'ביזם אתם משלמים על מוצר מוגמר עם ערבויות חוק מכר. בקבוצת רכישה אתם שותפים בסיכון - אם יש עיכובים, חריגות בעלויות או בעיות משפטיות, אתם נושאים בהן. לכן הבדיקה המקדימה קריטית.',
  },
  {
    question: 'מה הסיכונים העיקריים בקבוצת רכישה?',
    answer: 'הסיכונים כוללים: עיכובים בבנייה (ממוצע 2-4 שנים יותר מהמתוכנן), חריגות בתקציב (10-30% מעל ההערכה), בעיות משפטיות עם הקרקע, מארגנים לא אמינים, וחוסר ערבויות כמו בחוק מכר. בדיקה מקצועית יכולה לזהות את הסיכונים מראש.',
  },
  {
    question: 'האם תמיד ההמלצה היא לא להצטרף?',
    answer: 'לא. יש קבוצות רכישה איכותיות עם מארגנים מנוסים, קרקע נקייה והסכם הוגן. המטרה שלנו היא לתת לכם תמונה מלאה ואובייקטיבית כדי שתקבלו החלטה מושכלת - לא להפחיד ולא לשכנע.',
  },
  {
    question: 'מה לעשות אם כבר חתמתי על הסכם?',
    answer: 'גם אחרי חתימה אפשר לבדוק את מצב הפרויקט, לזהות סימני אזהרה ולתכנן צעדים. אם יש בעיות, נעזור לכם להבין את האפשרויות - כולל משא ומתן, התייעצות משפטית או יציאה מההסכם אם אפשרי.',
  },
  {
    question: 'האם אתם יכולים להמליץ על קבוצות רכישה טובות?',
    answer: 'אנחנו לא ממליצים על קבוצות ספציפיות ואין לנו קשרים עם מארגנים. התפקיד שלנו הוא לבדוק את הקבוצה שאתם שוקלים ולתת חוות דעת אובייקטיבית. כך אנחנו שומרים על ניטרליות מוחלטת.',
  },
];

const serviceSteps = [
  { number: 1, title: 'קבלת חומרים', description: 'שליחת מסמכי הקבוצה: הסכם, מפרט, תוכניות, ומידע על הקרקע והמארגן.' },
  { number: 2, title: 'בדיקה מקיפה', description: 'בדיקת הקרקע, המארגן, ההסכם והכלכלה. השוואה לשוק ולפרויקטים דומים.' },
  { number: 3, title: 'דוח והמלצה', description: 'דוח מפורט עם ממצאים, סיכונים, ונקודות למשא ומתן. המלצה ברורה.' },
  { number: 4, title: 'ליווי (אופציונלי)', description: 'ליווי בחתימה, מו״מ על תנאים, ומעקב לאורך הפרויקט.' },
];

// Service schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'בדיקת קבוצת רכישה',
  description: 'בדיקה מקצועית של קבוצות רכישה על ידי שמאית מקרקעין מוסמכת. בדיקת קרקע, מארגן, הסכם והמלצה אובייקטיבית.',
  provider: {
    '@type': 'ProfessionalService',
    name: 'השקעות נדל״ן - מעין ואור ליבנה',
    url: 'https://hashkaot-nadlan.co.il',
    telephone: '+972-55-432-9232',
  },
  areaServed: ['חיפה', 'קריות', 'נשר', 'נתניה', 'ראשון לציון', 'מרכז הארץ'],
  serviceType: 'בדיקת קבוצת רכישה',
  offers: {
    '@type': 'Offer',
    priceRange: '3500-12000',
    priceCurrency: 'ILS',
    description: 'בדיקה בסיסית עד מקיפה',
  },
};
---

<BaseLayout
  title="בדיקת קבוצת רכישה"
  description="חושבים להצטרף לקבוצת רכישה? בדיקה מקצועית של הקרקע, המארגן וההסכם. המלצה אובייקטיבית האם כדאי להצטרף. שמאית מקרקעין מוסמכת עם 15 שנות ניסיון."
>
  <SchemaOrg schema={serviceSchema} />

  <PageHero
    title="בדיקת קבוצת רכישה"
    subtitle="לפני שחותמים על הסכם הצטרפות לקבוצת רכישה - בדיקה מקצועית של הקרקע, המארגן וההסכם. המלצה אובייקטיבית ללא ניגוד אינטרסים."
    
    backgroundImage="/images/hero/hero-01.webp"
    showCTA={true}
    ctaText="שלחו לנו את פרטי הקבוצה"
  />

  <TrustBar variant="light" />

  <!-- Intro Section - Buying Group Risks -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-6 text-center">
          קבוצת רכישה - הזדמנות או סיכון?
        </h2>

        <div class="prose prose-lg max-w-none text-muted">
          <p>
            קבוצות רכישה מוצגות לעיתים כדרך לחסוך עשרות אחוזים ממחיר דירה מיזם. המציאות מורכבת יותר. בעוד שיש קבוצות איכותיות שמספקות ערך אמיתי, רבות מסתיימות בעיכובים של שנים, חריגות תקציב משמעותיות, או אפילו קריסה מוחלטת.
          </p>
          <p>
            ההבדל בין קבוצה מוצלחת לכושלת טמון בפרטים: איכות הקרקע, ניסיון המארגן, תנאי ההסכם והמבנה הכלכלי. <strong>בדיקה מקצועית לפני החתימה</strong> יכולה לחסוך לכם שנים של עוגמת נפש ומאות אלפי שקלים.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Questions to Ask Yourself -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          לפני שחותמים - שאלו את עצמכם
        </h2>

        <div class="bg-white rounded-2xl p-6 md:p-8 border border-border">
          <ul class="space-y-4">
            {[
              'האם הקרקע רשומה על שם המארגן או על שם חברי הקבוצה?',
              'מה קורה אם יש עיכוב בקבלת היתר בנייה?',
              'האם יש ערבות בנקאית או ביטוח לכספים שלכם?',
              'מה ניסיון המארגן בפרויקטים קודמים? האם הושלמו בזמן ובתקציב?',
              'מה קורה אם עלויות הבנייה עולות מעל ההערכה?',
              'האם יש סעיף יציאה בהסכם? באילו תנאים?',
              'מה העמלות הנסתרות? ניהול, שיווק, ליווי משפטי?',
              'האם המחיר הסופי באמת נמוך מדירה חדשה מיזם באותו אזור?',
            ].map((question) => (
              <li class="flex items-start gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-warning-100 rounded-full flex items-center justify-center mt-0.5">
                  <span class="text-warning-600 text-sm font-bold">?</span>
                </div>
                <span class="text-dark">{question}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-6 border-t border-border">
            <p class="text-muted text-center">
              אם אין לכם תשובות ברורות לשאלות האלה - <strong>אל תחתמו לפני בדיקה מקצועית</strong>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Check - 4 Items -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          מה אנחנו בודקים?
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">בדיקת הקרקע</h3>
            <p class="text-muted">
              בעלות, שעבודים, תב״ע, זכויות בנייה, הערות אזהרה, היתרים קיימים, והתאמה לתוכניות המוצגות. בדיקה ברשם המקרקעין ובוועדות התכנון.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">בדיקת המארגן</h3>
            <p class="text-muted">
              ניסיון קודם, פרויקטים שהושלמו, תלונות ותביעות, מצב פיננסי, ומוניטין בשוק. ראיונות עם רוכשים מפרויקטים קודמים.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">ניתוח ההסכם</h3>
            <p class="text-muted">
              סעיפי יציאה, אחריות המארגן, חלוקת סיכונים, תנאי תשלום, ערבויות, ומה קורה בתרחישי קיצון. זיהוי סעיפים בעייתיים.
            </p>
          </div>

          <div class="p-6 bg-surface rounded-xl border border-border">
            <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-semibold text-dark text-lg mb-2">השוואת מחירים</h3>
            <p class="text-muted">
              חישוב העלות הסופית הצפויה (כולל עמלות ותוספות), והשוואה לדירות חדשות מיזם באותו אזור. האם באמת יש חיסכון משמעותי?
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pros and Cons -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          יתרונות וחסרונות של קבוצת רכישה
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Pros -->
          <div class="bg-white rounded-2xl p-6 border border-success-200">
            <h3 class="font-semibold text-success-700 text-lg mb-4 flex items-center gap-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              יתרונות אפשריים
            </h3>
            <ul class="space-y-3">
              {[
                'חיסכון של 10-25% לעומת יזם (בקבוצה איכותית)',
                'אפשרות להתאמה אישית של הדירה',
                'שקיפות בעלויות (אם ההסכם טוב)',
                'תחושת שותפות ומעורבות בפרויקט',
                'לפעמים מיקומים שלא זמינים ביזמות',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-success-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-dark">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Cons -->
          <div class="bg-white rounded-2xl p-6 border border-error-200">
            <h3 class="font-semibold text-error-700 text-lg mb-4 flex items-center gap-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              סיכונים וחסרונות
            </h3>
            <ul class="space-y-3">
              {[
                'עיכובים משמעותיים (ממוצע 2-4 שנים יותר מהמתוכנן)',
                'חריגות בתקציב (10-30% מעל ההערכה)',
                'אין ערבויות חוק מכר - אתם בסיכון',
                'תלות במארגן - אם נופל, הפרויקט נתקע',
                'חוסר ודאות לגבי המוצר הסופי',
                'קושי ביציאה אחרי חתימה',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-error-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  <span class="text-dark">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps
    title="תהליך הבדיקה"
    subtitle="ארבעה שלבים לקבלת החלטה מושכלת"
    steps={serviceSteps}
  />

  <!-- Pricing -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-8 text-center">
          עלות הבדיקה
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Basic -->
          <div class="bg-surface rounded-2xl p-6 border border-border">
            <div class="text-center mb-6">
              <h3 class="font-semibold text-dark text-xl mb-2">בדיקה בסיסית</h3>
              <div class="text-3xl font-bold text-brand-600">3,500-5,000 ש״ח</div>
            </div>

            <ul class="space-y-3 mb-6">
              {[
                'בדיקת בעלות ושעבודים על הקרקע',
                'בדיקת רקע על המארגן',
                'סקירת סעיפים מרכזיים בהסכם',
                'זיהוי סיכונים עיקריים',
                'המלצה כללית (כדאי/לא כדאי)',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-muted">{item}</span>
                </li>
              ))}
            </ul>

            <p class="text-sm text-muted text-center">מתאים למי שרוצה בדיקה מהירה לפני קבלת החלטה</p>
          </div>

          <!-- Full -->
          <div class="bg-brand-50 rounded-2xl p-6 border-2 border-brand-300 relative">
            <div class="absolute -top-3 right-6 bg-brand-600 text-white text-sm px-3 py-1 rounded-full">
              מומלץ
            </div>

            <div class="text-center mb-6">
              <h3 class="font-semibold text-dark text-xl mb-2">בדיקה מקיפה</h3>
              <div class="text-3xl font-bold text-brand-600">8,000-12,000 ש״ח</div>
            </div>

            <ul class="space-y-3 mb-6">
              {[
                'כל מה שכלול בבדיקה בסיסית',
                'ניתוח כלכלי מלא של הפרויקט',
                'השוואת מחירים לשוק (דירות מיזם)',
