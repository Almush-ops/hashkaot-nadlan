---
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs: Array<{ label: string; href?: string }>;
  backgroundImage?: string;
  showCTA?: boolean;
  ctaText?: string;
  ctaHref?: string;
  phoneText?: string;
}

const {
  title,
  subtitle,
  breadcrumbs,
  backgroundImage = '/images/hero/hero-02.webp',
  showCTA = false,
  ctaText = 'השאירו פרטים',
  ctaHref = '#contact',
  phoneText = '055-432-9232',
} = Astro.props;
---

<section class="relative min-h-[50vh] flex items-center overflow-hidden">
  <!-- Background Image with Dark Overlay -->
  <div class="absolute inset-0">
    <img
      src={backgroundImage}
      alt=""
      class="w-full h-full object-cover"
      width="1820"
      height="1024"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-l from-brand-900/95 via-brand-800/90 to-brand-900/85"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-4 relative z-10 py-16 md:py-24">
    <div class="mb-4">
      <Breadcrumbs items={breadcrumbs} variant="light" />
    </div>

    <div class="max-w-3xl">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-8">
          {subtitle}
        </p>
      )}

      {showCTA && (
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={ctaHref}
            class="group flex items-center justify-center gap-2 px-8 py-4 bg-accent hover:bg-accent-dark text-brand-900 rounded-xl font-bold text-lg transition-all duration-300 hover:shadow-2xl hover:shadow-accent/30 hover:-translate-y-1"
          >
            <span>{ctaText}</span>
            <svg class="w-5 h-5 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={`tel:${phoneText}`}
            class="flex items-center justify-center gap-3 px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm border-2 border-white/30 hover:border-white text-white rounded-xl font-semibold text-lg transition-all duration-300"
          >
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-green-400"></span>
            </span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>{phoneText}</span>
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute top-0 end-0 w-64 h-64 bg-accent/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 start-0 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
</section>
