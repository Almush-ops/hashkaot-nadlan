---
const phone = '055-2555144';
const email = 'maayan@maayanlivne.co.il';
const address = 'כביש ההר הירוק, יגור';
const currentYear = new Date().getFullYear();

const services = [
  { label: 'ליווי משקיעים', href: '/livuy-mashkiim/' },
  { label: 'בדיקת עסקת קרקע', href: '/bdikat-iska-karka/' },
];

const quickLinks = [
  { label: 'אודות', href: '/about/' },
  { label: 'צור קשר', href: '/contact/' },
];

const legalLinks = [
  { label: 'תנאי שימוש', href: '/terms/' },
  { label: 'מדיניות פרטיות', href: '/privacy/' },
  { label: 'הצהרת נגישות', href: '/accessibility/' },
];
---

<footer class="bg-brand-900 text-white">
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">הנ</span>
          </div>
          <div>
            <div class="font-heading font-bold text-lg">השקעות נדל"ן</div>
            <div class="text-sm text-white/70">מעין ואור ליבנה</div>
          </div>
        </a>
        <p class="text-white/70 text-sm leading-relaxed">
          שמאית מקרקעין שמלווה משקיעים - שילוב נדיר של מקצועיות ושקיפות בעולם השקעות הנדל"ן.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">שירותים</h3>
        <ul class="space-y-2">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-accent transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">ניווט מהיר</h3>
        <ul class="space-y-2">
          {quickLinks.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-accent transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4">צור קשר</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${phone}`} class="text-white/70 hover:text-accent transition-colors">{phone}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${email}`} class="text-white/70 hover:text-accent transition-colors">{email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/70">{address}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-white/50 text-sm">
          &copy; {currentYear} השקעות נדל"ן - מעין ואור ליבנה. כל הזכויות שמורות.
        </div>
        <div class="flex items-center gap-4">
          {legalLinks.map((item) => (
            <a href={item.href} class="text-white/50 hover:text-white text-sm transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
