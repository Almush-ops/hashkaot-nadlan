---
// TODO: Almog - provide phone number for lead tracking
const phone = '';
const email = 'office@hashkaot-nadlan.co.il';
const address = 'כביש ההר הירוק, יגור';
const currentYear = new Date().getFullYear();

const services = [
  { label: 'ליווי משקיעים לרכישת דירה', href: '/investor-consulting/' },
  { label: 'ליווי רכישת קרקע', href: '/land-purchase-consulting/' },
  { label: 'בדיקת עסקת קרקע', href: '/land-deal-assessment/' },
  { label: 'בדיקת כדאיות דירה', href: '/apartment-investment-analysis/' },
  { label: 'התחדשות עירונית', href: '/urban-renewal/' },
];

const popularGuides = [
  { label: 'תשואה על השקעה בנדל״ן 2026', href: '/blog/tashuva-nadlan-2026/' },
  { label: 'נדל״ן למתחילים - המדריך המלא', href: '/blog/nadlan-lematchilim/' },
  { label: 'הון עצמי לדירה להשקעה', href: '/blog/hon-atzmi-dira-lehaskaa/' },
  { label: 'שמאי מקרקעין vs מתווך', href: '/blog/shamai-vs-metavech/' },
];

const serviceAreas = [
  { name: 'חיפה', href: '/areas/haifa/' },
  { name: 'הקריות', href: '/areas/krayot/' },
  { name: 'נשר', href: '/areas/nesher/' },
  { name: 'נתניה', href: '/areas/netanya/' },
  { name: 'ראשון לציון', href: '/areas/rishon/' },
  { name: 'גבעת שמואל', href: '/areas/givat-shmuel/' },
];

const quickLinks = [
  { label: 'אודות', href: '/about/' },
  { label: 'בלוג', href: '/blog/' },
  { label: 'צור קשר', href: '/contact/' },
];

const legalLinks = [
  { label: 'תנאי שימוש', href: '/terms/' },
  { label: 'מדיניות פרטיות', href: '/privacy/' },
  { label: 'הצהרת נגישות', href: '/accessibility/' },
];

const socialLinks = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=61550130013520',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/maayan_livne/',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/maayan-livne-b7b493214',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`
  },
];

// Trust signals
const trustSignals = [
  { value: '15+', label: 'שנות ניסיון' },
  { value: '617+', label: 'עסקאות' },
  { value: '5.0', label: 'דירוג' },
];
---

<footer class="bg-brand-900 text-white">
  <!-- Main Footer -->
  <div class="container mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand Column with Trust Signals -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img src="/logo-light.svg" alt="השקעות נדל״ן - מעין ואור ליבנה" class="h-12 w-auto" />
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          שמאית מקרקעין שמלווה משקיעים - שילוב נדיר של מקצועיות ושקיפות בעולם השקעות הנדל"ן.
        </p>

        <!-- Trust Signals -->
        <div class="grid grid-cols-3 gap-3 mb-5 p-4 bg-white/5 rounded-lg">
          {trustSignals.map((signal) => (
            <div class="text-center">
              <div class="text-accent font-bold text-lg">{signal.value}</div>
              <div class="text-white/50 text-xs">{signal.label}</div>
            </div>
          ))}
        </div>

        <!-- Certification Badge -->
        <div class="flex items-center gap-2 mb-5 text-white/60 text-sm">
          <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>שמאית מקרקעין מוסמכת</span>
        </div>

        <!-- Social Links -->
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="w-9 h-9 bg-white/10 hover:bg-accent rounded-lg flex items-center justify-center text-white/70 hover:text-white transition-all duration-300"
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          שירותים
        </h3>
        <ul class="space-y-2.5">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-accent transition-colors flex items-center gap-2 group">
                <svg class="w-3 h-3 text-accent/50 group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Quick Links -->
        <div class="mt-6 pt-4 border-t border-white/10">
          <ul class="space-y-2">
            {quickLinks.map((item) => (
              <li>
                <a href={item.href} class="text-white/70 hover:text-accent transition-colors text-sm">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Guides/Resources Column -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          מדריכים
        </h3>
        <ul class="space-y-2.5">
          {popularGuides.map((item) => (
            <li>
              <a href={item.href} class="text-white/70 hover:text-accent transition-colors flex items-start gap-2 group">
                <svg class="w-3 h-3 mt-1.5 text-accent/50 group-hover:text-accent transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="leading-snug">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog/" class="mt-4 inline-flex items-center gap-2 text-accent hover:text-accent-light transition-colors text-sm font-medium group">
          <span>כל המאמרים</span>
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-heading font-bold text-lg mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          צור קשר
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/70">{address}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${phone}`} class="text-white/70 hover:text-accent transition-colors">{phone || 'יצרו קשר לשיחה'}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${email}`} class="text-white/70 hover:text-accent transition-colors">{email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-white/70">א׳-ה׳ 09:00-18:00</span>
          </li>
        </ul>

        <!-- CTA Button -->
        <a
          href="/contact/"
          class="mt-6 inline-flex items-center justify-center gap-2 w-full bg-accent hover:bg-accent-dark text-brand-900 font-bold py-3 px-4 rounded-lg transition-all shadow-lg shadow-accent/20 hover:shadow-accent/30 group"
        >
          <span>ייעוץ ראשוני חינם</span>
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Service Areas Strip -->
    <div class="mt-10 pt-6 border-t border-white/10">
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-sm">
        <span class="text-white/50 ml-2">אזורי שירות:</span>
        {serviceAreas.map((area, index) => (
          <>
            <a href={area.href} class="text-white/70 hover:text-accent transition-colors">{area.name}</a>
            {index < serviceAreas.length - 1 && <span class="text-white/30">•</span>}
          </>
        ))}
        <span class="text-white/30">•</span>
        <a href="/areas/" class="text-accent hover:text-accent-light transition-colors font-medium">כל האזורים</a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-white/50 text-sm">
          &copy; {currentYear} השקעות נדל"ן - מעין ואור ליבנה. כל הזכויות שמורות.
        </div>
        <div class="flex items-center gap-4 flex-wrap justify-center">
          {legalLinks.map((item) => (
            <a href={item.href} class="text-white/50 hover:text-white text-sm transition-colors">
              {item.label}
            </a>
          ))}
          <span class="text-white/30">|</span>
          <a href="/contact/" class="text-white/50 hover:text-white text-sm transition-colors">
            צור קשר
          </a>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="mt-4 text-center">
        <p class="text-white/40 text-xs max-w-3xl mx-auto leading-relaxed">
          המידע באתר הינו כללי בלבד ואינו מהווה ייעוץ משפטי, פיננסי או אישי מחייב.
          הנתונים והחישובים מוצגים להמחשה בלבד. לקבלת ייעוץ מותאם אישית יש לפנות לצוות שלנו.
        </p>
      </div>
    </div>
  </div>
</footer>
