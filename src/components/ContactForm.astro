---
interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'standalone' | 'section';
}

const {
  title = 'השאירו פרטים ונחזור אליכם',
  subtitle = 'מלאו את הפרטים ונציג יחזור אליכם בהקדם לייעוץ ראשוני ללא התחייבות.',
  variant = 'section',
} = Astro.props;

const services = [
  { value: 'livuy-mashkiim', label: 'ליווי משקיעים לרכישת דירה' },
  { value: 'bdikat-karka', label: 'בדיקת עסקת קרקע' },
  { value: 'bdikat-kedaiut', label: 'בדיקת כדאיות דירה' },
  { value: 'hitchadshut', label: 'התחדשות עירונית' },
  { value: 'other', label: 'אחר' },
];

const regions = [
  { value: 'tzafon', label: 'צפון' },
  { value: 'merkaz', label: 'מרכז' },
  { value: 'darom', label: 'דרום' },
];
---

<section id="contact" class={`py-16 md:py-20 ${variant === 'section' ? 'bg-surface' : ''}`}>
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-10">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
          {title}
        </h2>
        {subtitle && (
          <p class="text-muted text-lg">
            {subtitle}
          </p>
        )}
      </div>

      <!-- Form -->
      <form
        id="lead-form"
        class="bg-white rounded-xl shadow-lg p-6 md:p-8 space-y-6"
      >
        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-dark mb-2">
            שם מלא <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
            placeholder="הכניסו את שמכם"
          />
        </div>

        <!-- Phone -->
        <div>
          <label for="phone" class="block text-sm font-medium text-dark mb-2">
            טלפון <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            dir="ltr"
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition text-right"
            placeholder="050-0000000"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-dark mb-2">
            אימייל
          </label>
          <input
            type="email"
            id="email"
            name="email"
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
            placeholder="your@email.com"
          />
        </div>

        <!-- Service -->
        <div>
          <label for="service" class="block text-sm font-medium text-dark mb-2">
            סוג שירות
          </label>
          <select
            id="service"
            name="service"
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition bg-white"
          >
            <option value="">בחרו שירות</option>
            {services.map((s) => (
              <option value={s.value}>{s.label}</option>
            ))}
          </select>
        </div>

        <!-- Region -->
        <div>
          <label for="region" class="block text-sm font-medium text-dark mb-2">
            אזור בארץ
          </label>
          <select
            id="region"
            name="region"
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition bg-white"
          >
            <option value="">בחרו אזור</option>
            {regions.map((r) => (
              <option value={r.value}>{r.label}</option>
            ))}
          </select>
        </div>

        <!-- Notes -->
        <div>
          <label for="notes" class="block text-sm font-medium text-dark mb-2">
            הערות נוספות
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            class="w-full px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition resize-none"
            placeholder="ספרו לנו עוד על מה שאתם מחפשים..."
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full py-4 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg"
        >
          שלחו ונחזור אליכם
        </button>

        <!-- Privacy note -->
        <p class="text-xs text-muted text-center">
          בשליחת הטופס אתם מאשרים את <a href="/privacy/" class="underline hover:text-brand-600">מדיניות הפרטיות</a> שלנו.
        </p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('lead-form');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const h1 = document.querySelector('h1')?.textContent?.trim() || document.title;

    const data = {
      name: formData.get('name'),
      phone: formData.get('phone'),
      email: formData.get('email') || '',
      service: formData.get('service') || '',
      region: formData.get('region') || '',
      notes: formData.get('notes') || '',
      'page-title': h1,
      source: 'hashkaot-nadlan.co.il',
      timestamp: new Date().toISOString(),
    };

    // TODO: Replace with actual webhook URL
    const webhookUrl = 'https://n8n.almush.co.il/webhook/hashkaot-nadlan-lead';

    try {
      const response = await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        // Redirect to thank you page
        window.location.href = '/thank-you/';
      } else {
        alert('אירעה שגיאה. אנא נסו שוב או התקשרו אלינו.');
      }
    } catch (error) {
      alert('אירעה שגיאה. אנא נסו שוב או התקשרו אלינו.');
    }
  });
</script>
