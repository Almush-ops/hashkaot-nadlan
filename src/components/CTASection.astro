---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  phoneText?: string;
  variant?: 'dark' | 'accent';
}

const {
  title,
  subtitle,
  ctaText = 'השאירו פרטים',
  ctaHref = '#contact',
  phoneText = '055-2555144',
  variant = 'dark',
} = Astro.props;

const bgClass = variant === 'accent' ? 'bg-accent' : 'bg-brand-700';
---

<section class={`py-12 md:py-16 ${bgClass}`}>
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-8">
      <!-- Text -->
      <div class="text-center md:text-start">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-2">
          {title}
        </h2>
        {subtitle && (
          <p class="text-white/80 text-lg">
            {subtitle}
          </p>
        )}
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={ctaHref}
          class="w-full sm:w-auto px-8 py-4 bg-white hover:bg-surface text-brand-700 rounded-md font-semibold transition-all duration-300 hover:shadow-lg text-center"
        >
          {ctaText}
        </a>
        <a
          href={`tel:${phoneText}`}
          class="w-full sm:w-auto flex items-center justify-center gap-2 px-8 py-4 bg-transparent border-2 border-white/30 hover:border-white text-white rounded-md font-semibold transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>{phoneText}</span>
        </a>
      </div>
    </div>
  </div>
</section>
