---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  backgroundImage?: string;
}

const {
  title,
  subtitle,
  ctaText = 'השאירו פרטים לייעוץ חינם',
  ctaHref = '#contact',
  secondaryCtaText = 'לשירותים שלנו',
  secondaryCtaHref = '/livuy-mashkiim/',
  backgroundImage = '/images/hero/hero-01.webp',
} = Astro.props;

const stats = [
  { value: '17%', label: 'תשואה ממוצעת', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>` },
  { value: '120+', label: 'משקיעים ליווינו', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>` },
  { value: '750+', label: 'בדיקות וייעוצים', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>` },
  { value: '5.0', label: 'דירוג ב-41 ביקורות', icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>` },
];
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden">
  <!-- Background with Gradient -->
  <div class="absolute inset-0 bg-gradient-to-l from-brand-900 via-brand-800 to-brand-700"></div>
  <!-- Subtle texture overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(201,162,39,0.15),transparent_50%)]"></div>

  <!-- Couple Image - Desktop (bottom-aligned, left side in RTL = end-0) -->
  <div class="hidden lg:block absolute bottom-0 end-0 z-10 w-[40%] max-w-[500px]">
    <img
      src="/images/team/or-maayan-together.png"
      alt="אור ומעיין ליבנה - מלווי משקיעים"
      class="w-full h-auto object-contain object-bottom"
      width="500"
      height="600"
      loading="eager"
    />
  </div>

  <div class="container mx-auto px-4 relative z-10 py-8 lg:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Main Content (first = right side in RTL) -->
      <div class="text-center lg:text-start pt-24 lg:pt-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 backdrop-blur-sm border border-accent/30 rounded-full mb-6">
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
          <span class="text-accent font-medium text-sm">שמאית מקרקעין מוסמכת</span>
        </div>

        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          {title}
        </h1>

        {subtitle && (
          <p class="text-lg md:text-xl text-white/80 max-w-xl mb-8 leading-relaxed">
            {subtitle}
          </p>
        )}

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4 mb-8">
          <a
            href={ctaHref}
            class="group w-full sm:w-auto px-8 py-4 bg-accent hover:bg-accent-dark text-brand-900 rounded-lg font-bold text-lg transition-all duration-300 hover:shadow-2xl hover:shadow-accent/30 hover:-translate-y-1 flex items-center justify-center gap-2"
          >
            <span>{ctaText}</span>
            <svg class="w-5 h-5 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={secondaryCtaHref}
            class="w-full sm:w-auto px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white border border-white/20 rounded-lg font-semibold text-lg transition-all duration-300 text-center"
          >
            {secondaryCtaText}
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 text-white/60 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span>ללא התחייבות</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>מענה תוך 24 שעות</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>צפון ומרכז הארץ</span>
          </div>
        </div>

        <!-- Stats Row - Desktop -->
        <div class="hidden lg:flex items-center gap-6 mt-8 pt-8 border-t border-white/20">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-2xl font-bold text-accent">
                {stat.value}
              </div>
              <div class="text-xs text-white/60">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Spacer for image on desktop (second = left side in RTL) -->
      <div class="hidden lg:block"></div>
    </div>

    <!-- Mobile: Couple Image + Stats -->
    <div class="lg:hidden mt-8">
      <!-- Mobile Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        {stats.map((stat) => (
          <div class="text-center bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/10">
            <div class="text-2xl md:text-3xl font-bold text-accent mb-1">
              {stat.value}
            </div>
            <div class="text-xs text-white/70">
              {stat.label}
            </div>
          </div>
        ))}
      </div>

      <!-- Mobile Couple Image -->
      <div class="flex justify-center">
        <img
          src="/images/team/or-maayan-together.png"
          alt="אור ומעיין ליבנה - מלווי משקיעים"
          class="w-full max-w-sm h-auto object-contain"
          width="400"
          height="500"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 animate-bounce hidden md:block z-20">
    <div class="w-8 h-12 border-2 border-white/30 rounded-full flex items-start justify-center p-2">
      <div class="w-1.5 h-3 bg-white/50 rounded-full animate-scroll"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.5; }
  }
  .animate-scroll {
    animation: scroll 1.5s ease-in-out infinite;
  }
</style>
