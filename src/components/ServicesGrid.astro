---
interface Service {
  title: string;
  description: string;
  href: string;
  icon: string;
}

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'השירותים שלנו', subtitle } = Astro.props;

const services: Service[] = [
  {
    title: 'ליווי משקיעים לרכישת דירה',
    description: 'ליווי מקיף מהרגע הראשון עד סגירת העסקה - איתור נכסים, בדיקת כדאיות, ניהול משא ומתן ועוד.',
    href: '/livuy-mashkiim/',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  },
  {
    title: 'בדיקת עסקת קרקע',
    description: 'בדיקה מקיפה על ידי שמאית מוסמכת - תכנון, משפטי, כלכלי. כדי שתדעו בדיוק מה אתם קונים.',
    href: '/bdikat-iska-karka/',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
  },
  {
    title: 'בדיקת כדאיות דירה',
    description: 'ניתוח פיננסי מקיף - תשואה צפויה, עלויות נלוות, השוואה לחלופות. קבלת החלטה מושכלת.',
    href: '/contact/',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  },
];
---

<section class="py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
        {title}
      </h2>
      {subtitle && (
        <p class="text-muted text-lg">
          {subtitle}
        </p>
      )}
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {services.map((service) => (
        <a
          href={service.href}
          class="group block bg-white border border-brand-100 rounded-xl p-6 md:p-8 transition-all duration-300 hover:shadow-lg hover:border-brand-200 hover:-translate-y-1"
        >
          <div class="w-14 h-14 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600 mb-5 group-hover:bg-brand-100 transition-colors">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="font-heading text-xl font-bold text-dark mb-3 group-hover:text-brand-600 transition-colors">
            {service.title}
          </h3>
          <p class="text-muted leading-relaxed mb-4">
            {service.description}
          </p>
          <span class="inline-flex items-center gap-2 text-brand-600 font-medium group-hover:gap-3 transition-all">
            למידע נוסף
            <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
