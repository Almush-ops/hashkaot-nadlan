---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'הסמכות מקצועיות',
  subtitle = 'תעודות והסמכות רשמיות - ההוכחה למומחיות שלנו'
} = Astro.props;

const certificates = [
  { src: '/images/certificates/cert-1.jpg', alt: 'תעודת שמאות מקרקעין' },
  { src: '/images/certificates/cert-2.jpg', alt: 'תעודת הסמכה מקצועית' },
  { src: '/images/certificates/cert-3.jpg', alt: 'רישיון תיווך' },
  { src: '/images/certificates/cert-4.jpg', alt: 'הסמכת יועץ משכנתאות' },
  { src: '/images/certificates/cert-5.jpg', alt: 'תעודת השתלמות' },
  { src: '/images/certificates/cert-6.jpg', alt: 'אישור מקצועי' },
];
---

<section class="py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-50 rounded-full mb-6">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
        <span class="text-brand-700 font-medium text-sm">מומחיות מוכחת</span>
      </div>

      <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
        {title}
      </h2>
      <p class="text-muted text-lg">
        {subtitle}
      </p>
    </div>

    <!-- Certificates Carousel/Grid -->
    <div class="relative">
      <!-- Gradient Fade Left -->
      <div class="absolute start-0 top-0 bottom-0 w-16 bg-gradient-to-l from-transparent to-white z-10 pointer-events-none"></div>
      <!-- Gradient Fade Right -->
      <div class="absolute end-0 top-0 bottom-0 w-16 bg-gradient-to-r from-transparent to-white z-10 pointer-events-none"></div>

      <!-- Scrollable Container -->
      <div id="cert-carousel" class="overflow-x-auto pb-4 -mx-4 px-4 scrollbar-hide scroll-smooth">
        <div class="flex gap-6 min-w-max">
          {certificates.map((cert, index) => (
            <div
              class="cert-item group relative w-48 md:w-56 flex-shrink-0 cursor-pointer"
              data-index={index}
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="aspect-[3/4] rounded-xl overflow-hidden bg-surface border-2 border-brand-100 transition-all duration-300 group-hover:border-brand-300 group-hover:shadow-xl group-hover:-translate-y-2">
                <img
                  src={cert.src}
                  alt={cert.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  width="224"
                  height="299"
                  loading="lazy"
                />
              </div>
              <!-- Label -->
              <div class="absolute -bottom-3 start-4 end-4 bg-white rounded-lg shadow-md px-3 py-2 text-center border border-brand-100 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span class="text-sm font-medium text-dark">{cert.alt}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Slider Dots -->
      <div class="flex justify-center gap-2 mt-6">
        {certificates.map((_, index) => (
          <button
            class="cert-dot w-2.5 h-2.5 rounded-full bg-brand-200 transition-all duration-300 hover:bg-brand-400"
            data-index={index}
            aria-label={`תעודה ${index + 1}`}
          />
        ))}
      </div>
    </div>

    <!-- Trust Message -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-6 flex-wrap justify-center">
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>שמאית מקרקעין מוסמכת</span>
        </div>
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>רישיון תיווך</span>
        </div>
        <div class="flex items-center gap-2 text-muted">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>יועץ משכנתאות מוסמך</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .cert-dot.active {
    @apply bg-brand-600 w-6;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('cert-carousel');
    const dots = document.querySelectorAll('.cert-dot');
    const items = document.querySelectorAll('.cert-item');

    if (!carousel || !dots.length) return;

    // Set first dot as active initially
    dots[0]?.classList.add('active');

    // Click handler for dots
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index);
        const item = items[index];
        if (item) {
          const scrollLeft = item.offsetLeft - carousel.offsetLeft - 16;
          carousel.scrollTo({ left: scrollLeft, behavior: 'smooth' });
        }
      });
    });

    // Scroll handler to update active dot
    let scrollTimeout;
    carousel.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const scrollLeft = carousel.scrollLeft;
        let activeIndex = 0;

        items.forEach((item, index) => {
          const itemLeft = item.offsetLeft - carousel.offsetLeft;
          if (scrollLeft >= itemLeft - 100) {
            activeIndex = index;
          }
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === activeIndex);
        });
      }, 50);
    });
  });
</script>
