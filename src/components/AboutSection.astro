---
interface Props {
  title?: string;
  variant?: 'homepage' | 'full';
}

const { title = 'הכירו את מעין ואור', variant = 'homepage' } = Astro.props;

const team = [
  {
    name: 'מעין ליבנה',
    role: 'שמאית מקרקעין מוסמכת',
    description: '15 שנות ניסיון בשמאות מקרקעין. התמחות בבדיקות השקעות ונכסים. מלווה משקיעים בהחלטות מבוססות נתונים.',
    credentials: ['שמאית מקרקעין מוסמכת', '15 שנות ניסיון', 'התמחות בהשקעות'],
  },
  {
    name: 'אור ליבנה',
    role: 'מלווה משקיעים',
    description: 'רקע בהייטק (אקזיט עם גרניולט שנמכרה לאינטל). יועץ משכנתאות ובעל רישיון תיווך. גישה אנליטית להשקעות.',
    credentials: ['רישיון תיווך', 'יועץ משכנתאות', 'רקע הייטק'],
  },
];

const highlights = [
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`, text: 'שקיפות מלאה - מראים גם סיכונים' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`, text: 'החלטות מבוססות נתונים' },
  { icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`, text: 'ליווי אישי - לא דרך שליחים' },
];
---

<section class="py-16 md:py-24 bg-surface overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image Side -->
      <div class="relative">
        <!-- Main Team Photo -->
        <div class="relative z-10">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="/images/team/maayan-or-hero.png"
              alt="מעין ואור ליבנה - מלווים משקיעי נדל״ן"
              class="w-full h-full object-cover"
              width="800"
              height="600"
              loading="lazy"
            />
          </div>

          <!-- Floating Stats Card -->
          <div class="absolute -bottom-6 -start-6 bg-white rounded-xl shadow-xl p-4 border border-brand-100">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-2xl font-bold text-dark">5.0</div>
                <div class="text-sm text-muted">41 ביקורות בגוגל</div>
              </div>
            </div>
          </div>

          <!-- Experience Badge -->
          <div class="absolute -top-4 -end-4 bg-brand-700 text-white rounded-xl shadow-lg p-4 text-center">
            <div class="text-3xl font-bold">15+</div>
            <div class="text-sm opacity-80">שנות ניסיון</div>
          </div>
        </div>

        <!-- Decorative Elements -->
        <div class="absolute -z-10 top-8 -start-8 w-full h-full bg-brand-100 rounded-2xl"></div>
        <div class="absolute -z-20 top-16 -start-16 w-full h-full border-2 border-brand-200 rounded-2xl"></div>
      </div>

      <!-- Content Side -->
      <div>
        <!-- Section Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-50 rounded-full mb-6">
          <span class="w-2 h-2 bg-brand-600 rounded-full"></span>
          <span class="text-brand-700 font-medium text-sm">מי אנחנו</span>
        </div>

        <h2 class="font-heading text-3xl md:text-4xl font-bold text-dark mb-6">
          {title}
        </h2>

        <p class="text-lg text-muted mb-8 leading-relaxed">
          שילוב נדיר של <strong class="text-dark">שמאית מקרקעין מוסמכת</strong> ו<strong class="text-dark">מלווה משקיעים עם רקע הייטק</strong> - המומחיות שאתם צריכים להשקעה חכמה ומבוססת נתונים.
        </p>

        <!-- Highlights -->
        <div class="space-y-4 mb-8">
          {highlights.map((item) => (
            <div class="flex items-center gap-4 p-4 bg-white rounded-xl border border-brand-100 transition-all duration-300 hover:shadow-md hover:border-brand-200">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-50 rounded-lg flex items-center justify-center text-brand-600">
                <Fragment set:html={item.icon} />
              </div>
              <span class="font-medium text-dark">{item.text}</span>
            </div>
          ))}
        </div>

        <!-- Team Cards (Compact) -->
        <div class="grid grid-cols-2 gap-4 mb-8">
          {team.map((member) => (
            <div class="bg-white rounded-xl p-4 border border-brand-100">
              <h3 class="font-heading font-bold text-dark mb-1">{member.name}</h3>
              <p class="text-brand-600 text-sm font-medium">{member.role}</p>
            </div>
          ))}
        </div>

        {variant === 'homepage' && (
          <a
            href="/about/"
            class="group inline-flex items-center gap-2 px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white rounded-lg font-semibold transition-all duration-300 hover:shadow-lg"
          >
            <span>קראו עוד על הצוות</span>
            <svg class="w-5 h-5 rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
