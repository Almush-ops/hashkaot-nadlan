---
interface Props {
  title?: string;
  variant?: 'homepage' | 'full';
}

const { title = 'הכירו את מעין ואור', variant = 'homepage' } = Astro.props;

const team = [
  {
    name: 'מעין ליבנה',
    role: 'שמאית מקרקעין מוסמכת',
    description: '15 שנות ניסיון בשמאות מקרקעין. התמחות בבדיקות השקעות ונכסים. מלווה משקיעים בהחלטות מבוססות נתונים.',
    credentials: ['שמאית מקרקעין מוסמכת', '15 שנות ניסיון', 'התמחות בהשקעות'],
  },
  {
    name: 'אור ליבנה',
    role: 'מלווה משקיעים',
    description: 'רקע בהייטק (אקזיט עם גרניולט שנמכרה לאינטל). יועץ משכנתאות ובעל רישיון תיווך. גישה אנליטית להשקעות.',
    credentials: ['רישיון תיווך', 'יועץ משכנתאות', 'רקע הייטק'],
  },
];
---

<section class="py-16 md:py-20 bg-surface">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
        {title}
      </h2>
      <p class="text-muted text-lg">
        שילוב נדיר של שמאית מקרקעין מוסמכת ומלווה משקיעים עם רקע הייטק - המומחיות שאתם צריכים להשקעה חכמה.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {team.map((member) => (
        <div class="bg-white rounded-xl p-6 md:p-8 border border-border">
          <!-- Avatar placeholder -->
          <div class="w-24 h-24 bg-brand-100 rounded-full mx-auto mb-6 flex items-center justify-center">
            <span class="text-3xl font-bold text-brand-600">{member.name.charAt(0)}</span>
          </div>

          <!-- Info -->
          <div class="text-center">
            <h3 class="font-heading text-xl font-bold text-dark mb-1">
              {member.name}
            </h3>
            <p class="text-brand-600 font-medium mb-4">
              {member.role}
            </p>
            <p class="text-muted leading-relaxed mb-6">
              {member.description}
            </p>

            <!-- Credentials -->
            <div class="flex flex-wrap justify-center gap-2">
              {member.credentials.map((credential) => (
                <span class="inline-block px-3 py-1 bg-brand-50 text-brand-700 text-sm rounded-full">
                  {credential}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    {variant === 'homepage' && (
      <div class="text-center mt-10">
        <a
          href="/about/"
          class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-medium transition-colors"
        >
          <span>קראו עוד על הצוות</span>
          <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
