---
interface Testimonial {
  name: string;
  text: string;
  role?: string;
  rating?: number;
}

interface Props {
  title?: string;
  subtitle?: string;
  testimonials?: Testimonial[];
}

const {
  title = 'מה אומרים עלינו',
  subtitle = 'הלקוחות שלנו מספרים על החוויה שלהם',
  testimonials = [
    {
      name: 'יוסי כהן',
      text: 'מעין ואור ליוו אותנו ברכישת הדירה הראשונה להשקעה. השקיפות והמקצועיות היו מדהימות. קיבלנו ניתוח מעמיק של כל נכס וחסכנו הרבה כסף.',
      role: 'משקיע מתחיל',
      rating: 5,
    },
    {
      name: 'שירה לוי',
      text: 'הבדיקה של מעין לקרקע שרצינו לקנות חסכה לנו מעל 200,000 ש״ח. היא זיהתה בעיות תכנוניות שלא ידענו עליהן.',
      role: 'רוכשת קרקע',
      rating: 5,
    },
    {
      name: 'אבי מזרחי',
      text: 'העבודה עם אור הייתה מהנה ומקצועית. הרקע שלו מההייטק מרגיש בגישה המבוססת נתונים. ממליץ בחום!',
      role: 'משקיע מנוסה',
      rating: 5,
    },
  ],
} = Astro.props;

const renderStars = (rating: number) => {
  return Array.from({ length: 5 }, (_, i) => i < rating);
};
---

<section class="py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4">
        {title}
      </h2>
      {subtitle && (
        <p class="text-muted text-lg">
          {subtitle}
        </p>
      )}
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-surface rounded-xl p-6 md:p-8 border border-border">
          <!-- Rating Stars -->
          {testimonial.rating && (
            <div class="flex gap-1 mb-4">
              {renderStars(testimonial.rating).map((filled) => (
                <svg
                  class={`w-5 h-5 ${filled ? 'text-accent' : 'text-border'}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}

          <!-- Quote -->
          <blockquote class="text-dark leading-relaxed mb-6">
            "{testimonial.text}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-dark">{testimonial.name}</div>
              {testimonial.role && (
                <div class="text-sm text-muted">{testimonial.role}</div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google Reviews Link -->
    <div class="text-center mt-10">
      <a
        href="https://share.google/CvHMxR13gTp3Flp4r"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-600 hover:text-brand-700 font-medium transition-colors"
      >
        <span>ראו את כל הביקורות בגוגל</span>
        <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
