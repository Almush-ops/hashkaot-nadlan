---
// TODO: Almog - צריך טלפון שלנו לפני העלאה לאוויר!
const phone = '';
const currentPath = Astro.url.pathname;

const services = [
  { label: 'ליווי משקיעים לרכישת דירה', href: '/investor-consulting/' },
  { label: 'ליווי רכישת קרקע', href: '/land-purchase-consulting/' },
  { label: 'בדיקת עסקת קרקע', href: '/land-deal-assessment/' },
  { label: 'בדיקת כדאיות דירה', href: '/apartment-investment-analysis/' },
  { label: 'בדיקת קבוצת רכישה', href: '/buying-group/' },
  { label: 'התחדשות עירונית', href: '/urban-renewal/' },
];

const navItems = [
  { label: 'אזורי פעילות', href: '/areas/' },
  { label: 'בלוג', href: '/blog/' },
  { label: 'אודות', href: '/about/' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function isServiceActive(): boolean {
  return services.some(s => currentPath.startsWith(s.href));
}
---

<header class="sticky top-0 z-40 bg-white border-b border-border">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img src="/logo.svg" alt="השקעות נדל״ן - מעין ואור ליבנה" class="h-12 md:h-14 w-auto" />
      </a>

      <!-- Desktop Navigation + CTA (grouped on left side in RTL) -->
      <div class="hidden md:flex items-center gap-6 ms-auto">
        <nav class="flex items-center gap-1">
          <!-- Services Dropdown -->
          <div class="relative group">
            <button
              class={`flex items-center gap-1 px-4 py-2 rounded-md text-sm font-medium transition-colors ${
                isServiceActive()
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-dark hover:text-brand-600 hover:bg-brand-50'
              }`}
            >
              <span>שירותים</span>
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full start-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-lg shadow-xl border border-border py-2 min-w-[220px]">
                {services.map((service) => (
                  <a
                    href={service.href}
                    class={`block px-4 py-2.5 text-sm transition-colors ${
                      isActive(service.href)
                        ? 'text-brand-600 bg-brand-50'
                        : 'text-dark hover:text-brand-600 hover:bg-brand-50'
                    }`}
                  >
                    {service.label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          {navItems.map((item) => (
            <a
              href={item.href}
              class={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${
                isActive(item.href)
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-dark hover:text-brand-600 hover:bg-brand-50'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Phone CTA -->
        <a
          href={`tel:${phone}`}
          class="flex items-center gap-2 px-4 py-2 bg-accent hover:bg-accent-dark text-white rounded-md font-medium transition-all duration-300 hover:shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>{phone}</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-10 h-10 flex items-center justify-center text-dark"
        aria-label="תפריט"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-border">
    <nav class="container mx-auto px-4 py-4">
      <!-- Services Section -->
      <div class="mb-4">
        <div class="px-4 py-2 text-sm font-semibold text-muted">שירותים</div>
        <div class="space-y-1">
          {services.map((service) => (
            <a
              href={service.href}
              class={`block px-4 py-3 rounded-md font-medium ${
                isActive(service.href)
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-dark hover:text-brand-600 hover:bg-brand-50'
              }`}
            >
              {service.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Other Links -->
      <div class="border-t border-border pt-4 space-y-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`block px-4 py-3 rounded-md font-medium ${
              isActive(item.href)
                ? 'text-brand-600 bg-brand-50'
                : 'text-dark hover:text-brand-600 hover:bg-brand-50'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Phone CTA -->
      <div class="pt-4 border-t border-border mt-4">
        <a
          href={`tel:${phone}`}
          class="flex items-center justify-center gap-2 px-4 py-3 bg-accent text-white rounded-md font-medium"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>התקשרו עכשיו: {phone}</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');

    if (isOpen) {
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>
